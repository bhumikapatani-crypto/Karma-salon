{{ 'section-products-grid.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-badge.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

<script src="{{ 'products-grid.js' | asset_url }}" defer="defer"></script>

{%- if settings.quickview_show or settings.show_on_mobile -%}
  {% comment %}theme-check-disable AssetPreload{% endcomment %}
  <link
    rel="stylesheet"
    href="{{ 'component-deferred-media.css' | asset_url }}"
    media="all"
  >
  <link
    rel="preload"
    href="{{ 'quick-add.css' | asset_url }}"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  >
  {% comment %}theme-check-enable AssetPreload{% endcomment %}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  assign grid_products = collections.all.products
  assign collection_handle = 'all'
  assign base_url = routes.all_products_collection_url
  assign total_shop_products = shop.products_count | default: 0

  if section.settings.collection != blank
    assign grid_products = section.settings.collection.products
    assign collection_handle = section.settings.collection.handle
    assign base_url = routes.collections_url | append: '/' | append: collection_handle
    assign total_shop_products = section.settings.collection.all_products_count
  endif

  if section.settings.product_list != blank
    assign grid_products = section.settings.product_list
    assign collection_handle = 'all'
    assign base_url = 'none'
    assign total_shop_products = section.settings.product_list.size
  endif

  assign sort = section.settings.sort

  case section.settings.sort
    when 'alphabetical'
      assign sort = 'title-ascending'
    when 'alphabetical_reversed'
      assign sort = 'title-descending'
    when 'products_high'
      assign sort = 'price-descending'
    when 'products_low'
      assign sort = 'price-ascending'
    when 'date'
      assign sort = 'created-ascending'
    when 'date_reversed'
      assign sort = 'created-descending'
    else
      assign sort = 'manual'
  endcase

  case sort
    when 'title-ascending', 'title-descending'
      assign grid_products = grid_products | sort: 'title'
    when 'price-descending', 'price-ascending'
      assign grid_products = grid_products | sort: 'price_min'
    when 'created-ascending', 'created-descending'
      assign grid_products = grid_products | sort: 'published_at'
    when 'manual'
      assign grid_products = grid_products | sort: 'manual'
    when 'best-selling'
      assign grid_products = grid_products | sort: 'manual'
  endcase

  if sort == 'price-descending' or sort == 'created-descending' or sort == 'title-descending'
    assign grid_products = grid_products | reverse
  endif

  assign btn_link = routes.collections_url | append: '/' | append: collection_handle | append: '?sort_by=' | append: sort

  if section.settings.section_button_link != blank
    assign btn_link = section.settings.section_button_link
  endif

  assign is_dynamic_loading = false
  if total_shop_products > 50
    assign is_dynamic_loading = true
  elsif sort == 'manual' or sort == 'best-selling'
    if base_url != 'none'
      assign is_dynamic_loading = true
    endif
  endif

  if is_dynamic_loading and base_url != 'none'
    assign sort_params = '?sort_by=' | append: sort
    # Using Section Rendering API https://shopify.dev/docs/api/ajax/section-rendering
    assign collection_url = base_url | append: sort_params | append: '&section_id=' | append: section.id
    assign grid_products = collection.products
  else
    assign collection_url = 'none'
  endif

  assign margin = 24
  if section.settings.card_type == 'type3'
    assign margin = 0
  endif

  assign swipe_on_mobile = section.settings.swipe_on_mobile
%}

<div
  class="products-grid{% if is_dynamic_loading %} products-grid--loading{% if collection.products.size > 0 %} products-grid--search-perfomed{% endif %}{% endif %}"
  data-is-dynamic-load="{{ is_dynamic_loading }}"
  data-collection-url="{{ collection_url }}"
  data-slider-mobile="{{ swipe_on_mobile }}"
>
  <div class="container">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: btn_link,
      button_style: section.settings.section_button_style
    %}

    <div class="products-grid__content">
      <div class="loading-overlay">
        <div class="loading-overlay__spinner">
          {% render 'icon-spinner' %}
        </div>
      </div>
      <div
        class="{% if swipe_on_mobile %}swiper--products-grid{% endif %}"
        data-columns-mobile="{{section.settings.columns_mobile}}"
        data-margin="{{ margin }}"
      >
        <div class="products-grid__wrapper products-grid__wrapper--{{ section.settings.columns_per_row }} products-grid__wrapper--{{ section.settings.columns_mobile }}-mobile {% if section.settings.card_type == 'type3' %} product-card-overlay {% endif %}">
          {% if is_dynamic_loading == false or grid_products.size > 0 %}
            {%- for product in grid_products limit: section.settings.products_per_page -%}
              <div class="collection-product-card {% if settings.quickview_hover %}quickview--hover{% endif %}">
                {% if section.settings.card_type == 'type1' %}
                  {% render 'product-card',
                    product_card_product: product,
                    media_size: section.settings.image_ratio,
                    media_fit: section.settings.image_fit,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_collection: section.settings.show_collection,
                    show_desc: section.settings.show_desc,
                    section_id: section.id,
                    columns: section.settings.columns_per_row,
                    add_id: forloop.index
                  %}
                {% elsif section.settings.card_type == 'type2' %}
                  {% render 'product-card-second',
                    product_card_product: product,
                    media_size: section.settings.image_ratio,
                    media_fit: section.settings.image_fit,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_collection: section.settings.show_collection,
                    show_inedex: section.settings.show_inedex,
                    show_desc: section.settings.show_desc,
                    section_id: section.id,
                    columns: section.settings.columns_per_row,
                    add_id: forloop.index
                  %}
                {% else %}
                  {% render 'product-card-overlay',
                    product_card_product: product,
                    media_size: section.settings.image_ratio,
                    media_fit: section.settings.image_fit,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_collection: section.settings.show_collection,
                    show_inedex: section.settings.show_inedex,
                    show_desc: section.settings.show_desc,
                    card_opacity_overlay: section.settings.card_opacity_overlay,
                    section_id: section.id,
                    columns: section.settings.columns_per_row,
                    add_id: forloop.index
                  %}
                {% endif %}
              </div>
            {%- endfor -%}
          {% else %}
            {%- for i in (1..4) -%}
              <div class="collection-popular-card collection-popular-card--placeholder">
                {% render 'product-card-placeholder',
                  media_size: section.settings.image_ratio,
                  forloop: forloop,
                  show_vendor: section.settings.show_vendor
                %}
              </div>
            {%- endfor -%}
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.products-grid.name",
  "tag": "section",
  "class": "products-grid-section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["*"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.products-grid.settings.collection.label"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "t:sections.products-grid.settings.product_list.label",
      "info": "t:sections.products-grid.settings.product_list.info",
      "limit": 50
    },
    {
      "type": "paragraph",
      "content": "t:sections.products-grid.settings.text_about_products.content"
    },
    {
      "type": "paragraph",
      "content": "t:sections.products-grid.settings.text_about_dynamic.content"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 50,
      "step": 1,
      "default": 12,
      "label": "t:sections.products-grid.settings.products_per_page.label"
    },
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 6,
      "label": "t:sections.all.columns.label",
      "info": "t:sections.all.columns.info"
    },
    {
      "type": "select",
      "id": "sort",
      "options": [
        {
          "value": "alphabetical",
          "label": "t:sections.products-grid.settings.sort.options__1.label"
        },
        {
          "value": "alphabetical_reversed",
          "label": "t:sections.products-grid.settings.sort.options__2.label"
        },
        {
          "value": "date_reversed",
          "label": "t:sections.products-grid.settings.sort.options__3.label"
        },
        {
          "value": "date",
          "label": "t:sections.products-grid.settings.sort.options__4.label"
        },
        {
          "value": "products_high",
          "label": "t:sections.products-grid.settings.sort.options__5.label"
        },
        {
          "value": "products_low",
          "label": "t:sections.products-grid.settings.sort.options__6.label"
        },
        {
          "value": "manual",
          "label": "t:sections.products-grid.settings.sort.options__7.label"
        },
        {
          "value": "best-selling",
          "label": "t:sections.products-grid.settings.sort.options__8.label"
        }
      ],
      "default": "alphabetical",
      "label": "t:sections.products-grid.settings.sort.label",
      "info": "t:sections.products-grid.settings.sort.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.all.mobile_options.swipe.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_card.content"
    },
    {
      "type": "select",
      "id": "card_type",
      "label": "t:sections.all.card.card_type.label",
      "options": [
        {
          "value": "type1",
          "label": "t:sections.all.card.card_type.options__1.label"
        },
        {
          "value": "type2",
          "label": "t:sections.all.card.card_type.options__2.label"
        },
        {
          "value": "type3",
          "label": "t:sections.all.card.card_type.options__3.label"
        }
      ],
      "default": "type1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "3/4",
      "label": "t:sections.all.image.aspect_ratio.label_secondary",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.image.fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.image.fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.image.fit.label_secondary"
    },
    {
      "type": "range",
      "id": "card_opacity_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.all.card.opacity_overlay.label",
      "info": "t:sections.all.card.opacity_overlay.info",
      "default": 0.1
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "t:sections.all.card.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection",
      "default": false,
      "label": "t:sections.all.card.show_collection.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.all.card.show_desc.info"
    },
    {
      "type": "checkbox",
      "id": "show_inedex",
      "default": false,
      "label": "t:sections.all.card.show_inedex.label",
      "info": "t:sections.all.card.show_inedex.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading.label__tag",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "section_button_label",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "t:sections.all.button.button_link.label",
      "info": "t:sections.products-grid.settings.button_link.info"
    },
    {
      "type": "select",
      "id": "section_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.products-grid.name"
    }
  ]
}
{% endschema %}
