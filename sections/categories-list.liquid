{{ 'section-categories-list.css' | asset_url | stylesheet_tag }}
<script src="{{ 'categories-list.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-margin' %}
	{% render 'section-padding' %}
{%- endstyle -%}

{% liquid
	assign columns_per_row = section.settings.columns_per_row
	assign image_ratio = section.settings.image_ratio
	assign object_fit = section.settings.object_fit
	assign columns_mobile = section.settings.columns_mobile
%}

<div class="categories-list{% if section.settings.enable_background %} categories-list--background{% endif %} color-{{ section.settings.section_color_scheme }}
  section-{{ section.id }}-padding{% if section.settings.notebook_bg %} notebook-bg{% endif %}" data-animation="{{ section.settings.is_animated_big_heading }}">
	<div class="container">
		{%- if section.settings.heading_big != blank -%}
			<h2 class="categories-list__heading_big h0 {% if section.settings.is_animated_big_heading %} animated-heading{% endif %} {{ section.settings.heading_direction }}"
				data-speed="{{ section.settings.big_heading_animation_speed }}" 
				data-animated_text="{{ section.settings.heading_big }}"
			>
				<span
					class="{% if section.settings.is_animated_big_heading %} animated-heading--inner{% endif %}"
					{% if section.settings.is_animated_big_heading %}
						style="opacity: 0;"
					{% endif %}
				>
					{{- section.settings.heading_big -}}
				</span>
			</h2>
		{%- endif -%}
		
		{% render 'section-header',
			section_heading: section.settings.section_heading,
			section_description: section.settings.description,
			button_label: section.settings.section_button_label,
			button_link: section.settings.section_button_link,
			button_style: section.settings.section_button_style,
			heading_direction: section.settings.heading_direction
		%}

		<div class="categories-list__main">
				<div class="categories-list__content swiper swiper--collections">
				<div
					class="categories-list__wrapper product-{{ columns_per_row }} categories-list__wrapper--{{columns_mobile}}-mobile swiper-wrapper"
					data-count-mobile="{{ columns_mobile }}"
					data-count="{{ columns_per_row }}"
				>
					{%- for block in section.blocks -%}
						{% liquid
							if block.settings.image != blank
								assign collection_image = block.settings.image
							else
								assign collection_image = block.settings.collection.featured_image
							endif
						%}
							{% if collection.title != block.settings.collection.title or collection.title == blank %}
								<div
									class="categories-list__item swiper-slide {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
									{{ block.shopify_attributes }}
									data-id="{{ block.id }}"
									{% if settings.animations_reveal_on_scroll %}
										data-cascade
										style="--animation-order: {{ forloop.index }};"
									{% endif %}
								>
									{% style %}
										#shopify-section-{{ section.id }} [data-id="{{ block.id }}"].categories-list__item {
												--aspect-ratio: {{ image_ratio }};
											}
									{% endstyle %}

									<div class="categories-list__item-inner {% if section.settings.img_hover %} categories-list__item-inner-hover {% endif %} categories-list__item-inner--{{section.settings.images_shape}} color-background-2 {{ image_ratio }}">
										{% if block.settings.collection != blank %}
											<a
												href="{{ block.settings.collection.url }}"
												class="categories-list__overlay-link"
												aria-label="{{ block.settings.collection.title }}"
											></a>
										{% endif %}
										<div class="categories-list__image">
											{% if collection_image != blank or block.settings.video != blank %}
												{% case columns_per_row %}
													{% when 8 %}
														{% capture sizes %}
														(min-width: 1600px) calc((100vw - 128px) / 8), (min-width: 1360px) calc((100vw - 128px) / 6), (min-width: 1100px) calc((100vw - 128px) / 4), (min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 7 %}
														{% capture sizes %}
														(min-width: 1600px) calc((100vw - 128px) / 7), (min-width: 1360px) calc((100vw - 128px) / 6), (min-width: 1100px) calc((100vw - 128px) / 4), (min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 6 %}
														{% capture sizes %}
														(min-width: 1360px) calc((100vw - 128px) / 6), (min-width: 1100px) calc((100vw - 128px) / 4), (min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 5 %}
														{% capture sizes %}
														(min-width: 1360px) calc((100vw - 128px) / 5), (min-width: 1100px) calc((100vw - 128px) / 4), (min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 4 %}
														{% capture sizes %}
															(min-width: 1100px) calc((100vw - 128px) / 4), (min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 3 %}
														{% capture sizes %}
															(min-width: 990px) calc((100vw - 40px) / 3), (min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% when 2 %}
														{% capture sizes %}
															(min-width: 750px) calc((100vw - 40px) / 2), calc(100vw - 40px)
														{% endcapture %}
													{% else %}
														{% capture sizes %}
															calc(100vw - 40px)
														{% endcapture %}
												{% endcase %}
												{%- capture style -%}
													object-fit: {{ object_fit }};
												{%- endcapture -%}
												{% if block.settings.video == blank %}
													{{
														collection_image
														| image_url: width: collection_image.width
														| image_tag:
															loading: 'lazy',
															sizes: sizes,
															widths: '120, 160, 200, 240, 300, 360',
															style: style
													}}
													{% else %}
													{{ block.settings.video 
															| video_tag: loading: 'lazy',
																					sizes: sizes,
																					class: 'data-alt',
																					widths: '120, 160, 200, 240, 300, 360',
																					autoplay: true,
																					loop: true,
																					controls: false,
																					muted: true 
													}}
												{% endif %}
											{% else %}
												{% assign collection_index = forloop.index | modulo: 4 | plus: 1 %} 
												{{ 'collection-apparel-' | append: collection_index | placeholder_svg_tag: 'placeholder-svg' }}
											{% endif %}
										</div>
									</div>

									<h4 class="categories-list__item-title--standard h4">
											<a
												href="{{ block.settings.collection.url }}"
												class="categories-list__link button--link"
												aria-label="{{ block.settings.collection.title }}"
												{% if block.settings.collection == blank %}
													aria-disabled="true"
												{% endif %}
											>
												<span class="h4">
													{% if block.settings.collection != blank %}
														{{ block.settings.collection.title }}
													{% else %}
														{{'general.card.collection_name' | t }}
													{% endif %}
												</span>
												{% render 'icon-small-arrow' %}
											</a>
									</h4>

									{% if block.settings.collection != blank %}
										<a
											href="{{ block.settings.collection.url }}"
											class="categories-list__overlay-link"
											aria-label="{{ block.settings.collection.title }}"
										></a>
									{% endif %}
								</div>
							{% endif %}
					{%- endfor -%}
				</div>
			</div>
			{% if section.settings.show_arrows %}
				<div class="categories-list__button-prev swiper-button swiper-button-prev color-{{ section.settings.color_scheme }}{% if section.settings.show_bullets == false %} no_bullets{% endif %}">
					<div class="svg-embed">{% render 'icon-arrow' %}</div>
				</div>
				<div class="categories-list__button-next swiper-button swiper-button-next color-{{ section.settings.color_scheme }}{% if section.settings.show_bullets == false %} no_bullets{% endif %}">
					<div class="svg-embed">{% render 'icon-arrow' %}</div>
				</div>
			{% endif %}
			{% if section.settings.show_bullets %}
				<div class="categories-list__pagination swiper-pagination-fraction swiper-pagination"></div>
			{% endif %}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.categories-list.name",
	"tag": "section",
	"class": "categories-list-section spaced-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "section_color_scheme",
			"default": "background-1",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "range",
			"id": "columns_per_row",
			"min": 2,
			"max": 12,
			"step": 1,
			"default": 12,
			"label": "t:sections.all.columns.label",
			"info": "t:sections.all.columns.info"
		},
		{
      "type": "checkbox",
      "id": "enable_background",
      "default": true,
      "label": "t:sections.all.enable_background.label"
    },
		{
      "type": "checkbox",
      "id": "notebook_bg",
      "default": true,
      "label": "t:sections.all.notebook_bg.label"
    },
		{
			"type": "header",
			"content": "t:sections.all.mobile_options.header.content"
		},
		{
			"type": "select",
			"id": "columns_mobile",
			"default": "2",
			"label": "t:sections.all.mobile_options.columns.label",
			"options": [
				{
					"value": "1",
					"label": "t:sections.all.mobile_options.columns.options__1.label"
				},
				{
					"value": "2",
					"label": "t:sections.all.mobile_options.columns.options__2.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.slider_options.header.content"
		},
		{
			"type": "checkbox",
			"id": "show_arrows",
			"default": true,
			"label": "t:sections.all.slider_options.navigation.label"
		},
		{
			"type": "checkbox",
			"id": "show_bullets",
			"default": true,
			"label": "t:sections.all.slider_options.pagination.label"
		},
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-1",
			"label": "t:sections.all.slider_options.controls_color_scheme.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.image.header.content"
		},
		{
			"type": "select",
			"id": "images_shape",
			"default": "round",
			"label": "t:sections.all.image.shape.label",
			"options": [
				{
					"value": "square",
					"label": "t:sections.all.image.shape.options__1.label"
				},
				{
					"value": "round",
					"label": "t:sections.all.image.shape.options__2.label"
				}
			]
		},
		{
			"type": "select",
			"id": "image_ratio",
			"default": "1/1",
			"label": "t:sections.all.image.aspect_ratio.label",
			"options": [
				{
					"value": "1/1",
					"label": "t:sections.all.image.aspect_ratio.options__1.label"
				},
				{
					"value": "3/2",
					"label": "t:sections.all.image.aspect_ratio.options__2.label"
				},
				{
					"value": "3/4",
					"label": "t:sections.all.image.aspect_ratio.options__3.label"
				},
				{
					"value": "4/3",
					"label": "t:sections.all.image.aspect_ratio.options__4.label"
				},
				{
					"value": "16/9",
					"label": "t:sections.all.image.aspect_ratio.options__5.label"
				},
				{
					"value": "21/9",
					"label": "t:sections.all.image.aspect_ratio.options__6.label"
				}
			]
		},
		{
			"type": "select",
			"id": "object_fit",
			"options": [
				{
					"value": "contain",
					"label": "t:sections.all.image.fit.options__1.label"
				},
				{
					"value": "cover",
					"label": "t:sections.all.image.fit.options__2.label"
				}
			],
			"default": "cover",
			"label": "t:sections.all.image.fit.label"
		},
		{
			"type": "checkbox",
			"id": "img_hover",
			"default": false,
			"label": "t:settings_schema.product_card.settings.quickview_hover.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.heading.header.content"
		},
		{
      "type": "inline_richtext",
      "id": "heading_big",
			"default": "t:sections.categories-list.settings.heading_big.default",
      "label": "t:sections.all.heading.label"
    },
		{
			"type": "text",
			"id": "section_heading",
			"label": "t:sections.all.heading.label__22"
		},
		{
			"type": "select",
			"id": "section_heading_size",
			"options": [
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h2",
			"label": "t:sections.all.heading_size.label__5"
		},
		{
			"type": "inline_richtext",
			"id": "description",
			"label": "t:sections.all.text.label",
			"default": "t:sections.categories-list.settings.description.default"
		},
		{
			"type": "select",
			"id": "heading_direction",
			"default": "column",
			"label": "t:sections.all.heading_direction.label",
			"options": [
				{
					"value": "row",
					"label": "t:sections.all.heading_direction.option__1.label"
				},
				{
					"value": "column",
					"label": "t:sections.all.heading_direction.option__2.label"
				}
			]
		},
		{
      "type": "header",
      "content": "t:sections.image-banner.settings.heading_animation.label"
    },
		{
			"type": "checkbox",
			"id": "is_animated_big_heading",
			"default": true,
			"label": "t:sections.image-banner.settings.enable_heading_animation.label__2"
		},
		{
			"type": "range",
			"id": "big_heading_animation_speed",
			"min": 50,
			"max": 300,
			"step": 50,
			"label": "t:sections.image-banner.settings.heading_animation_speed.label",
			"default": 150
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "text",
			"id": "section_button_label",
			"default": "t:sections.categories-list.settings.section_button_label.default",
			"label": "t:sections.all.button.button_label.label",
			"info": "t:sections.all.button.button_label.info"
		},
		{
			"type": "url",
			"id": "section_button_link",
			"label": "t:sections.all.button.button_link.label"
		},
		{
			"type": "select",
			"id": "section_button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				}
			],
			"default": "tertiary",
			"label": "t:sections.all.button.button_style.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-padding.header.content"
		},
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-padding.padding_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-padding.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-padding.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-padding.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-padding.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-padding.padding_bottom.label"
		}
	],
	"blocks": [
		{
			"type": "collection_item",
			"name": "t:sections.categories-list.blocks.name",
			"settings": [
				{
					"type": "collection",
					"id": "collection",
					"label": "t:sections.categories-list.blocks.settings.collection.label"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:sections.categories-list.blocks.settings.image.label",
					"info": "t:sections.categories-list.blocks.settings.image.info"
				},
				{
					"type": "video",
					"id": "video",
					"label": "t:sections.all.video.label",
					"info": "t:sections.all.video.info"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.categories-list.presets.name",
			"blocks": [
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
					"type": "collection_item"
				},
				{
