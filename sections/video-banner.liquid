{{ 'section-video-banner.css' | asset_url | stylesheet_tag }}
<script src="{{ 'video-banner.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

<div
  class="video-banner {% if section.settings.scroll_animation and section.settings.header_overlay == false %}video-banner__scroll_animation{% endif %}"
  {% if section.settings.header_overlay == true and section.settings.scroll_animation == false %}
    data-header-overlay="true"
  {% endif %}
>
  <div
    id="Banner-{{ section.id }}"
    class="banner video--overlay {% if section.settings.video == blank %} banner--no-video {% endif %}"
  >
    <div class="video-banner__sticky_content">
      <div class="video-banner__content {% if section.settings.header_overlay and section.settings.scroll_animation == false %} color-background-2{% else %} color-{{ section.settings.color_scheme }}{% endif %} video-banner__content--mobile-overlay">
        {% if section.settings.video != blank %}
          <div
            class="banner__media media banner__media--{{- section.settings.video_fit -}} {% if section.settings.autoplay_video %} autoplay{% endif %}"
            data-video-id="{{ section.settings.video.id }}"
            {% if section.settings.loop_video == false %}
              data-video-loop="false"
            {% endif %}
          >
            {% liquid
              assign muted = section.settings.muted_video
              assign playsinline = false
              assign autoPlay = false

              if section.settings.autoplay_video == true
                assign muted = true
                assign autoPlay = true
              endif
            %}

            {{
              section.settings.video
              | video_tag:
                class: 'banner__media__video data-alt',
                image_size: '1920x',
                autoplay: autoPlay,
                loop: section.settings.loop_video,
                muted: muted,
                playsinline: playsinline
            }}
            <span
              class="banner__overlay"
              style="background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }});"
            ></span>
          </div>
        {% else %}
          <div class="banner__media media ">
            {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg' }}
            <span
              class="banner__overlay"
              style="background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }});"
            ></span>
          </div>
          <span
            class="banner__overlay"
            style="background-color: rgba(var(--color-overlay), {{ section.settings.opacity_overlay }});"
          ></span>
        {% endif %}

        <div class="video-banner__wrapper container media-large">
          <div class="video-banner__info">
            <div class="video-banner__controls">
              {% if section.settings.show_icon_play and section.settings.video != blank %}
                <button
                  class="button--unstyled button--play js-play-video{% if section.settings.autoplay_video %} active{% endif %}"
                  aria-label=" {{ 'general.video.play' | t }}"
                >
                  <span>
                    <span class="button-icon button-icon-pause">
                      {% render 'icon-pause' %}
                    </span>
                    <span class="button-icon button-icon-play">
                      {% render 'icon-play' %}
                    </span>
                  </span>
                </button>
              {% endif %}
              {% if section.settings.show_icon_sound and section.settings.video != blank %}
                <button
                  class="button--unstyled button--sound js-sound-video"
                  aria-label=" {{ 'general.video.sound' | t }}"
                >
                  <span>
                    <span class="button-icon {% if muted == false %} icon-hidden {% endif %} ">
                      {% render 'icon-sound-off' %}
                    </span>
                    <span class="button-icon {% if muted == true %} icon-hidden {% endif %}">
                      {% render 'icon-sound-on' %}
                    </span>
                  </span>
                </button>
              {% endif %}
            </div>
            <div
              class="
                video-banner__column
                {% if section.settings.heading != blank and section.settings.text == blank %} video-banner__column--center{% endif %}
                {% if section.settings.heading == blank and section.settings.text != blank %} video-banner__column--center{% endif %}
              "
            >
              <div class="video-banner__texts">
                {%- if section.settings.heading != blank -%}
                  <{{ section.settings.heading_tag }} class="{{ section.settings.heading_size }} video-banner__title title">
                    {{- section.settings.heading -}}
                  </{{ section.settings.heading_tag }}>
                {% endif %}
                {%- if section.settings.text != blank -%}
                  <div class="video-banner__description description">
                    {{ section.settings.text }}
                  </div>
                {% endif %}
              </div>
              {% if section.settings.button_label != blank %}
                {% render 'button',
                  btn_label: section.settings.button_label,
                  btn_link: section.settings.button_link,
                  btn_style: section.settings.button_style
                %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.video-banner.name",
  "tag": "section",
  "class": "video-banner-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "header_overlay",
      "label": "t:sections.all.header_overlay.label",
      "info": "t:sections.video-banner.settings.header_overlay.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "scroll_animation",
      "label": "t:sections.video-banner.settings.scroll_animation.label",
      "info": "t:sections.video-banner.settings.scroll_animation.info",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-2",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.content_options.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "t:sections.video-banner.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_tag.label",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "t:sections.video-banner.settings.text.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "t:sections.all.button.button_label.default_3",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.video-banner.settings.header__2.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.all.video.label"
    },
    {
      "type": "checkbox",
      "id": "autoplay_video",
      "label": "t:sections.video-banner.settings.autoplay_video.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "muted_video",
      "label": "t:sections.video-banner.settings.muted_video.label",
      "info": "t:sections.video-banner.settings.muted_video.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "t:sections.video-banner.settings.loop_video.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_play",
      "label": "t:sections.video-banner.settings.show_icon_play.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_icon_sound",
      "label": "t:sections.video-banner.settings.show_icon_sound.label",
      "default": true
    },
    {
      "type": "select",
      "id": "video_fit",
      "label": "t:sections.video-banner.settings.video_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.video-banner.settings.video_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.video-banner.settings.video_fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "opacity_overlay",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "t:sections.video-banner.settings.opacity_overlay.label",
      "default": 0.3
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.video-banner.presets.name"
    }
  ]
}
{% endschema %}
