{{ 'section-brands.css' | asset_url | stylesheet_tag }}
<script src="{{ 'brands.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-margin' %}
{%- endstyle -%}

{% liquid
	assign enable_swiper = section.settings.enable_swiper
	assign blocks_count = 0
	assign per_row = section.settings.columns_per_row
	assign columns_mobile = section.settings.columns_mobile
%}

{% for block in section.blocks %}
  {% assign blocks_count = blocks_count | plus: 1 %}
{% endfor %}


<div class="brands {% if enable_swiper and blocks_count > 1 %}swiper-enabled{% endif %}">
	<div class="container">
		{% render 'section-header',
			section_heading: section.settings.section_heading,
			section_description: section.settings.section_description,
			button_label: section.settings.section_button_label,
			button_link: section.settings.section_button_link,
			button_style: section.settings.section_button_style
		%}

		<div class="{% if enable_swiper and blocks_count > 1 %} swiper swiper__brands{% endif %}">
			<div class="brands__items col-{{ per_row }} colmob-{{ columns_mobile }} {% if enable_swiper and blocks_count > 1 %} swiper-wrapper{% endif %}" 
				data-countmob="{{columns_mobile}}"
				data-count="{{ per_row }}">
				{%- for block in section.blocks -%}
					<div class="brands__item-wrapper {% if enable_swiper and blocks_count > 1 %}swiper-slide{% endif %}">
						<a
							class="brands__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}" 
							{% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}
							{% if block.settings.brand_link.url != blank %}
								href="{{ block.settings.brand_link }}"
								aria-label="Brand Link {{ forloop.index }}"
							{% endif %}
							{% if block.settings.brand_link.url == blank %}
								aria-disabled="true"
							{% endif %}
							{{ block.shopify_attributes }}
						>
							{%- assign width = block.settings.image_width -%}
							{%- assign height = width | divided_by: block.settings.image_1.aspect_ratio | round: 2 -%}
							{% capture class %} brands__image brands__image--dark brands__image{{ forloop.index }} {% endcapture %}
							{% capture class2 %} brands__image brands__image--light brands__image{{ forloop.index }} {% endcapture %}
							{%- style -%}
								@media screen and (max-width: 1300px) {
									.brands__image{{ forloop.index }} {
										width: {{ block.settings.image_width | times: 0.8 | round: 0 }}px;
									}
								}
								@media screen and (max-width: 750px) {
									.brands__image{{ forloop.index }} {
										width: {{ block.settings.image_width }}px;
									}
								}
							{%- endstyle -%}
		
							{%- assign sizes = '(min-width: 1100px) 750, (min-width: 750px) 550, 275' -%}
							{%- if block.settings.image_2 != blank
								or block.settings.image_1 != blank
							-%}
								{%- if block.settings.image_2 != blank -%}
									{{
										block.settings.image_2
										| image_url: width: 710
										| image_tag:
											loading: 'lazy',
											sizes: sizes,
											widths: '275, 550, 750',
											height: height,
											width: width,
											class: class
									}}
								{%- endif -%}
								{%- if block.settings.image_1 != blank -%}
									{{
										block.settings.image_1
										| image_url: width: 710
										| image_tag:
											loading: 'lazy',
											sizes: sizes,
											widths: '275, 550, 750',
											height: height,
											width: width,
											class: class2
									}}
								{%- endif -%}
							{% else %}
								<div class="brands__placeholder">Brand</div>
							{%- endif -%}
						</a>
					</div>
				{% endfor %}
			</div>
			{%- if enable_swiper and blocks_count > 1 -%}
				{% if section.settings.show_arrows %}
					<div class="brands__button-prev swiper-button swiper-button-prev color-{{ settings.color_scheme }}">
						<div class="svg-embed">{% render 'icon-arrow' %}</div>
					</div>
					<div class="brands__button-next swiper-button swiper-button-next color-{{ settings.color_scheme }}">
						<div class="svg-embed">{% render 'icon-arrow' %}</div>
					</div>
				{% endif %}
			{% endif %}
		</div>
		
		{%- if enable_swiper and blocks_count > 1 -%}
			{% if section.settings.show_bullets %}
				<div class="brands__pagination swiper-pagination"></div>
			{% endif %}
		{% endif %}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.brands.name",
	"class": "spaced-section brands-section",
	"tag": "section",
	"max_blocks": 16,
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "range",
			"id": "columns_per_row",
			"min": 2,
			"max": 9,
			"step": 1,
			"default": 9,
			"label": "t:sections.all.columns.label",
			"info": "t:sections.all.columns.info"
		},
		{
			"type": "header",
			"content": "t:sections.all.mobile_options.header.content"
		},
		{
			"type": "select",
			"id": "columns_mobile",
			"default": "1",
			"label": "t:sections.all.mobile_options.columns.label",
			"options": [
				{
					"value": "1",
					"label": "t:sections.all.mobile_options.columns.options__1.label"
				},
				{
					"value": "2",
					"label": "t:sections.all.mobile_options.columns.options__2.label"
				}
			]
		},
		{
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "default": "t:sections.brands.settings.section_heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "section_description",
      "label": "t:sections.all.text.label",
      "default": "t:sections.brands.settings.section_description.default"
    },{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "text",
			"id": "section_button_label",
			"label": "t:sections.all.button.button_label.label",
			"info": "t:sections.all.button.button_label.info"
		},
		{
			"type": "url",
			"id": "section_button_link",
			"label": "t:sections.all.button.button_link.label"
		},
		{
			"type": "select",
			"id": "section_button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				}
			],
			"default": "secondary",
			"label": "t:sections.all.button.button_style.label"
		},
    {
			"type": "header",
			"content": "t:sections.all.slider_options.header.content"
		},
    {
      "type": "checkbox",
      "id": "enable_swiper",
      "label": "t:sections.all.slider.enable_slider.label",
      "default": false
    },
		{
			"type": "checkbox",
			"id": "show_arrows",
			"default": true,
			"label": "t:sections.all.slider_options.navigation.label"
		},
		{
			"type": "checkbox",
			"id": "show_bullets",
			"default": true,
			"label": "t:sections.all.slider_options.pagination.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"blocks": [
		{
			"type": "column",
			"name": "t:sections.brands.blocks.column.name",
			"settings": [
				{
					"type": "image_picker",
					"id": "image_1",
					"label": "t:sections.brands.blocks.column.settings.image_1.label"
				},
				{
					"type": "image_picker",
					"id": "image_2",
					"label": "t:sections.brands.blocks.column.settings.image_2.label"
				},
				{
					"type": "range",
					"id": "image_width",
					"min": 10,
					"max": 300,
					"step": 5,
					"default": 100,
					"unit": "px",
					"label": "t:sections.brands.blocks.column.settings.image_width.label"
				},
				{
					"type": "url",
					"id": "brand_link",
					"label": "t:sections.brands.blocks.column.settings.brand_link.label"
				}
			]
		}
	],
	"presets": [
		{
			"name": "t:sections.brands.name",
			"blocks": [
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				},
				{
					"type": "column"
				}
			]
		}
	]
}
{% endschema %}
