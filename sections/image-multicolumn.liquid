{{ 'section-image-multicolumn.css' | asset_url | stylesheet_tag }}
<script src="{{ 'image-multicolumn.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign indent_value = "2.4rem"
  assign columns_per_row = section.settings.columns_per_row
  assign image_ratio = section.settings.image_ratio

  if image_ratio != 'large'
    assign aspect_ratio = image_ratio
  else
    assign aspect_ratio = section.settings.aspect_ratio
  endif
%}

{% assign aspect_ratio_parts = aspect_ratio | split: "/" %}
{% assign width = aspect_ratio_parts[0] | plus: 0 %}
{% assign height = aspect_ratio_parts[1] | plus: 0 %}

{% assign padding_bottom = 100 | times: height | divided_by: width %}
{% assign padding_bottom = padding_bottom | append: "%" %}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}

  :root {
    {% if image_ratio != 'large' %}
      --aspect-ratio: {{ image_ratio }};
    {% else %}
      --aspect-ratio: {{ section.settings.aspect_ratio }};
    {% endif %}
    --padding-bottom: {{ padding_bottom }};
  }
{% endstyle %}

<div class="simple-image-multicolumn section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}
  {% if section.settings.enable_background %} simple-image-multicolumn--background {% endif %} {% if section.settings.notebook_bg %} notebook-bg {% endif %}">
  <div class="container">
    {% if section.settings.subheading %}
			<div class="simple-image-multicolumn__subheading subtitle">{{ section.settings.subheading }}</div>
		{% endif %}
  </div>


  <div class="simple-image-multicolumn__container">
    <div class="simple-image-multicolumn__wrapper container">
      <div class="simple-image-multicolumn-list {% if section.blocks.size > 1 %}swiper-container{% endif %}" data-columns="{{ columns_per_row }}">
        <div class="simple-image-multicolumn-list__wrapper {% if section.blocks.size > 1 %}swiper-wrapper{% endif %} simple-image-multicolumn-list__wrapper--{{ columns_per_row }} 
          simple-image-multicolumn-list__wrapper--{{ section.settings.columns_mobile }}-mobile"
          style="--indent_value: {{ indent_value }};"
        >
          {%- for block in section.blocks -%}
            
            {% liquid
              assign without_border_radius = false
              if indent_value == "0" and section.blocks.size > 1
                assign without_border_radius = true
              endif
            %}
            <div
              class="simple-image-multicolumn-card {% if section.blocks.size > 1 %}swiper-slide{% endif %} color-{{ block.settings.color_scheme }} {% if without_border_radius %} without-border-radius{% endif %}" 
              data-id="{{ block.id }}"
              {{ block.shopify_attributes }}
              tabindex="0"
              {% if block.settings.button_link %}
                 onclick="window.location.href='{{ block.settings.button_link }}'" style="cursor: pointer;"
              {% endif %}
            >{% style %}
              #shopify-section-{{ section.id }} [data-id="{{ block.id }}"] .simple-image-multicolumn-card__image {
                  {% if image_ratio != 'large' %}
                    --aspect-ratio: {{ image_ratio }};
                  {% else %}
                    --aspect-ratio: {{ section.settings.aspect_ratio }};
                  {% endif %}
                }
            {% endstyle %}
              {%- if block.settings.button_link != blank -%}
                <a
                  href="{{ block.settings.button_link }}"
                  class="simple-image-multicolumn-card__link-overlay"
                  aria-label="{{ block.settings.button_label }}"
                ></a>
              {%- endif -%}
                <div class="simple-image-multicolumn-card__image {{ image_ratio }}" style="--overlay-opacity: {{ block.settings.overlay_opacity }};">
                    {%- if block.settings.image != blank
                      and block.settings.video == blank
                    -%}
                      {%- capture sizes -%}
                        (min-width: 1100px) calc((100vw - 64px * 2)), calc((100vw - 20px * 2))
                      {%- endcapture -%}
                      {{
                        block.settings.image
                        | image_url: width: block.settings.image.width
                        | image_tag:
                          loading: 'lazy',
                          width: block.settings.image.width,
                          height: block.settings.image.height,
                          sizes: sizes,
                          widths: '360, 535, 720'
                       }}
                    
                    {%- elsif block.settings.video != blank -%}
                        {{
                          block.settings.video
                          | video_tag:
                            image_size: '1920x',
                            class: 'data-alt',
                            autoplay: true,
                            loop: true,
                            controls: false,
                            muted: true
                        }}
                    {%- else %}
                      {% assign cycle_index = forloop.index | modulo: 3 | plus: 1 %}
                      {% assign svg_placeholder_name = 'hero-apparel-' | append: cycle_index %}
                        {{
                          svg_placeholder_name
                          | placeholder_svg_tag: 'placeholder-svg'
                        }}
                    {%- endif -%}
                  {%- if block.settings.heading != blank or block.settings.text != blank or block.settings.button_label != blank -%}
                    <div class="simple-image-multicolumn-card__content">
                      {% if block.settings.button_link != blank %}
                        <div onclick="window.location.href=='{{ block.settings.button_link }}'">
                      {% endif %}
                        <div class="simple-image-multicolumn-card__info"> 
                          {%- if block.settings.heading != blank -%}
                            <h2 class="simple-image-multicolumn-card__heading {{section.settings.heading_size }}">
                              {{ block.settings.heading | escape | truncatewords: 10, "..." }}
                            </h2>
                          {%- endif -%}
                          {%- if block.settings.text != blank -%}
                            <div class="simple-image-multicolumn-card__text richtext__content">
                              {% assign truncated_text = block.settings.text | truncatewords: 10 | strip_html %}
                              {%- assign words_array = truncated_text | split: " " -%}
                              {% assign html_words_q = words_array | size %}
                              {% assign difference = 10 | minus: html_words_q %}

                              {% if difference > 0 %}
                                {% assign adjusted_word_limit = 10 | plus: difference %}
                              {% else %}
                                {% assign adjusted_word_limit = 10 %}
                              {% endif %}

                              {{ block.settings.text | truncatewords: adjusted_word_limit, "..." }}
                            </div>
                          {%- endif -%}
                          
                          {% if block.settings.button_label != blank %}
                            {% assign btn_label = block.settings.button_label | truncatewords: 5 %}
                            {% render 'button',
                              btn_label: btn_label,
                              btn_link: block.settings.button_link,
                              btn_style: block.settings.button_style,
                              add_classes: "simple-image-multicolumn__button"
                            %}
                          {% endif %}
                        </div>
                      {% if block.settings.button_link != blank %}
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.blocks.size > 1 -%}
          <div class="swipe-on-mobile__nav no-js-hidden">
            <div class="simple-image-multicolumn__pagination swiper-pagination swiper-pagination-fraction"></div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-multicolumn.name",
  "class": "image-multicolumn-section spaced-section",
  "tag": "section",
  "max_blocks": 12,
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
			"type": "text",
			"id": "subheading",
			"default": "t:sections.collection-slider.settings.subheading.default",
			"label": "t:sections.all.subheading.label"
		},
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_background",
      "default": false,
      "label": "t:sections.all.enable_background.label"
    },
    {
      "type": "checkbox",
      "id": "notebook_bg",
      "default": false,
      "label": "t:sections.all.notebook_bg.label"
    },
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 5,
      "label": "t:sections.all.columns.label",
      "info": "t:sections.all.columns.info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.image-multicolumn.settings.cards_heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
			"type": "select",
			"id": "columns_mobile",
			"default": "1",
			"label": "t:sections.all.mobile_options.columns.label",
			"options": [
				{
					"value": "1",
					"label": "t:sections.all.mobile_options.columns.options__1.label"
				},
				{
					"value": "2",
					"label": "t:sections.all.mobile_options.columns.options__2.label"
				}
			]
		},
    //{
    //  "type": "checkbox",
    //  "id": "swipe_on_mobile",
    //  "default": false,
    //  "label": "t:sections.all.mobile_options.swipe.label"
		//},
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "3/4",
      "label": "t:sections.all.image.aspect_ratio.label",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section-padding.header.content"
    },
		{
			"type": "select",
			"id": "padding_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "padding_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		},
