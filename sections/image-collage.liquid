{{ 'section-image-collage.css' | asset_url | stylesheet_tag }}
<script src="{{ 'image-collage.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign indent_value = '2.4rem'
  assign columns_per_row = section.settings.columns_per_row
  assign image_ratio = section.settings.image_ratio
%}

{% assign animated = false %}
{% if section.settings.swiper and section.blocks.size > 1 %}
  {% assign animated = true %}
{% endif %}

{% style %}
  {% render 'section-padding' %}
  {% render 'section-margin' %}

  :root {
    --indent_value: 2.4rem;
  }
{% endstyle %}

<div class="image-collage section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}">
  <div class="container{% if section.settings.h_direction == "column" %} column{% endif %}">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}
  </div>

  <div class="image-collage__container {% if animated == false %}container{% endif %}">
    <div class="image-collage__wrapper">
      <div class="image-collage-list {% if animated %}swiper-container{% endif %}" data-columns="{{ columns_per_row }}">
        <div
          class="
            image-collage-list__wrapper {% if animated %}swiper-wrapper{% endif %}{% if section.settings.gap %} gap{% endif %} image-collage-list__wrapper--{{ columns_per_row }}
            image-collage-list__wrapper--{{ section.settings.columns_mobile }}-mobile
          "
        >
          {%- for block in section.blocks -%}
            {% liquid
              assign without_border_radius = false
              if indent_value == '0' and animated
                assign without_border_radius = true
              endif
            %}
            <div
              class="image-collage-card {% if animated %}swiper-slide{% endif %}{% if section.settings.gap %} gap{% endif %} color-{{ block.settings.color_scheme }} {% if without_border_radius %} without-border-radius{% endif %}"
              data-id="{{ block.id }}"
              tabindex="0"
              {{ block.shopify_attributes }}
              {% if block.settings.overlay_link %}
                onclick="window.location.href='{{ block.settings.overlay_link }}'" style="cursor: pointer;"
              {% endif %}
            >
              {% style %}
                #shopify-section-{{ section.id }} [data-id="{{ block.id }}"] .image-collage-card__image {
                    {% if image_ratio != 'large' %}
                      --aspect-ratio: {{ image_ratio }};
                    {% else %}
                      --aspect-ratio: {{ section.settings.aspect_ratio }};
                    {% endif %}
                  }
              {% endstyle %}
              {%- if block.settings.overlay_link != blank -%}
                <a
                  href="{{ block.settings.overlay_link }}"
                  class="image-collage-card__link-overlay"
                  aria-label="Card Link {{ forloop.index }}"
                ></a>
              {%- endif -%}
              <div
                class="image-collage-card__image {{ image_ratio }}"
                style="--overlay-opacity: {{ block.settings.overlay_opacity }};"
              >
                {%- if block.settings.image != blank and block.settings.video == blank -%}
                  {%- capture sizes -%}
                        (min-width: 1100px) calc((100vw - 64px * 2)), calc((100vw - 20px * 2))
                      {%- endcapture -%}
                  {% liquid
                    if columns_per_row > 3
                      assign widths = '360, 535'
                    else
                      assign widths = '360, 535, 720, 940'
                    endif
                  %}
                  {{
                    block.settings.image
                    | image_url: width: block.settings.image.width
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.image.width,
                      height: block.settings.image.height,
                      sizes: sizes,
                      widths: widths
                  }}

                {%- elsif block.settings.video != blank -%}
                  {{
                    block.settings.video
                    | video_tag:
                      image_size: '1920x',
                      class: 'data-alt',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true
                  }}
                {%- else %}
                  {% assign cycle_index = forloop.index | modulo: 3 | plus: 1 %}
                  {% assign svg_placeholder_name = 'hero-apparel-' | append: cycle_index %}
                  {{ svg_placeholder_name | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if block.settings.heading != blank or block.settings.text != blank -%}
                  <div class="image-collage-card__content">
                    <div
                      class="image-collage-card__info"
                      {% if block.settings.overlay_link != blank %}
                        onclick="window.location.href='block.settings.overlay_link'"
                      {% endif %}
                    >
                      {%- if block.settings.heading != blank -%}
                        <div class="image-collage-card__heading">
                          {{ block.settings.heading | escape }}
                        </div>
                      {%- endif -%}
                      {%- if block.settings.text != blank -%}
                        <div class="image-collage-card__text richtext__content secondary_text">
                          {{ block.settings.text }}
                        </div>
                      {%- endif -%}
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if animated -%}
          <div class="swipe-on-mobile__nav no-js-hidden">
            <div class="image-collage__pagination swiper-pagination"></div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-collage.name",
  "class": "image-collage-section spaced-section",
  "tag": "section",
  "max_blocks": 12,
  "enabled_on": {
    "templates": ["*"]
