    }
  ],
  "blocks": [
    {
      "type": "image-collage_card",
      "name": "t:sections.image-collage.blocks.image-collage_card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.all.video.label",
          "info": "t:sections.all.video.info"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 1,
          "default": 0,
          "step": 0.1,
          "label": "t:sections.all.card.opacity_overlay.label",
          "info": "t:sections.all.card.opacity_overlay.info__2"
        },
        {
          "type": "header",
          "content": "t:sections.all.content_options.header.content"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "background-2",
          "label": "t:sections.image-collage.blocks.image-collage_card.color_scheme"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.all.heading.label"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:sections.all.text.label"
        },
