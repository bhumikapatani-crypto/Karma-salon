{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-search.css' | asset_url | stylesheet_tag }}
{{ 'template-search.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- if settings.quickview_show or settings.show_on_mobile -%}
  {% comment %}theme-check-disable AssetPreload{% endcomment %}
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">
  <link
    rel="preload"
    href="{{ 'quick-add.css' | asset_url }}"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  >
  {% comment %}theme-check-enable AssetPreload{% endcomment %}
{%- endif -%}

{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign terms = search.terms | escape
  assign search_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by 
-%}

<div class="template-search{% if search.performed == true and search.results_count == 0 and terms != blank %} template-search--empty {% else %} template-search--performed {% endif %} {% if search.performed == false %} template-search--empty {% endif %}">
  <div class="template-search__header">
    <div class="container">
    <div class="page-header">
      <div class="page-header__inner">
        {%- if search.performed -%}
          {% if search.performed == true and search.results_count == 0 and terms != blank %}
            <h1 class="main-page-title page-title title--page h2">
              {{ 'templates.search.no_results' | t: terms: search.terms }}
            </h1>
            <p class="search__header-des">{{ 'templates.search.no_results_3' | t }}</p>
          {% else %}
            <h1 class="main-page-title page-title title--page h2">
              {{ 'templates.search.title' | t }}: {{ terms }}
            </h1>
          {% endif %}
        {%- else -%}
          <h1 class="main-page-title page-title title--page h2">
            {{ 'general.search.search' | t }}
          </h1>
        {%- endif -%}
      </div>
    </div>
    <div class="template-search__search">
      {%- if settings.predictive_search_enabled -%}
        <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
      {%- endif -%}
        {%- if search.performed and search.results_count == 0 and search.filters == empty -%}
          <div class="search-wrapper">
        {% endif %}
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="search"
        >
          <div class="search__header">
            <div class="field">
              <input
                class="search__input field__input" 
                id="Search-In-Template" 
                type="search" 
                dir="ltr"
                name="q" 
                value="{{ search.terms | escape }}" 
                placeholder="{{ 'general.search.placeholder' | t }}"
                {%- if settings.predictive_search_enabled -%}
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results-list"
                  aria-controls="predictive-search-results-list"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                {%- endif -%}
              >
              <label class="visually-hidden" for="Search-In-Template">{{ 'general.search.search' | t }}</label>
              <input name="options[prefix]" type="hidden" value="last">
              <span class="search__input--icon-clear focus-inset" tabindex="0" aria-label="{{ 'accessibility.close' | t }}">
                {% render 'icon-close' %}
              </span>
              </div>
            <button
              class="search__button button button--primary focus-inset"
              aria-label="{{ 'general.search.search' | t }}"
            >
              <span>{{ 'general.search.search' | t }}</span>
              <div class="button-circle">
                <div class="svg-embed">
                  {% render 'icon-small-arrow' %}
                </div>
              </div>
            </button>
          </div>
          {%- if settings.predictive_search_enabled -%}
            <div class="search__container">
              <div class="predictive-search predictive-search--search-template" id="predictive-search-{{ section.id }}" tabindex="-1" data-predictive-search>
                <div class="predictive-search__loading-state">
                  {% render 'icon-spinner' %}
                </div>
              </div>
              <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
            </div>
          {%- endif -%}
        </form>
        {% comment %}{%- if search.performed and search.results_count == 0 and search.filters == empty -%}
          <p class="search__form-text" role="status">
            {{ 'templates.search.no_results' | t: terms: search.terms }}
          </p>
        {% elsif search.performed and search.results_count > 0 %}
          <p class="search__form-text" role="status">{{ 'templates.search.results' | t: count: search.results_count }}</p>
        {%- endif -%}{% endcomment %}
        {%- if search.performed and search.results_count == 0 and search.filters == empty -%}
          </div>
        {% endif %}
      {%- if settings.predictive_search_enabled -%}
        </predictive-search>
      {%- endif -%}
      {% if settings.enable_search_promo %}
        {% if settings.search_menu.links.size > 0
          or settings.search_product != blank
        %}
          <div class="search__container">
            <div class="search__inner search__inner-page" id="{{ section.id }}">
              {% if settings.search_menu.links.size > 0 %}
                {%
                  render 'promo-menu',
                  heading: settings.search_menu_heading,
                  search_menu: settings.search_menu,
                %}
              {% endif %}

              {% if settings.search_product != blank %}
                {% render 'promo-block',
                  heading: settings.search_block_heading,
                  product: settings.search_product,
                  image_ratio: settings.search_media_size,
                  image_fit: settings.search_media_fit,
                  show_secondary_image: settings.predictive_search_show_secondary_image,
                  show_arrows: settings.search_show_arrows,
                  columns_mobile: section.settings.columns_mobile,
                  show_bullets: settings.search_show_bullets
                %}
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endif %}
    </div>
  </div>
  </div>
  {%- if search.performed -%}
    {% liquid
      assign filter_show = false
      for filter in search.filters
        if filter.range_max != 0 
          assign filter_show = true
        endif
      endfor
    %}
    <div class="container">
      <div class="collection-wrapper collection-wrapper_no-facets">
        {%- if search.filters != empty -%}
          {%- if section.settings.enable_filtering and filter_show or section.settings.enable_sorting -%}
              {% render 'facets', 
                results: search, 
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                image_filter_ratio: section.settings.image_filter_ratio,
                image_filter_fit: section.settings.image_filter_fit,
                image_filter_columns: section.settings.image_filter_columns
              %}
          {%- endif -%}
        {%- endif -%}
      
        <div
          id="ProductGridContainer"
          class="products-grid products-grid_no-filter"
        >
        {% paginate search.results by 14 %}
          {%- if search.results.size == 0 and search.filters != empty -%}
            <div class="template-search__results collection collection-product" id="product-grid" data-id="{{ section.id }}">
              <div class="loading-overlay">
                <div class="loading-overlay__spinner">
                  {% render 'icon-spinner' %}
                </div>
              </div>
              <div class="title-wrapper center title-wrapper-empty">
                <div class="title title--primary">
                  {{ 'sections.collection_template.empty_results' | t }}
                  <br>
                  {{ 'sections.collection_template.results_use_fewer_filters_html' | t: link: search_url, class: "underlined-link link" }}
                </div>
              </div>
            </div>
          {%- else -%}
              <div class="template-search__results collection collection-product" id="product-grid" data-id="{{ section.id }}">
                <div class="loading-overlay">
                  <div class="loading-overlay__spinner">
                    {% render 'icon-spinner' %}
                  </div>
                </div>

                {% liquid
                  assign search_products = search.results | where: 'object_type', "product"
                  assign search_products_size = search_products | size
                  assign search_articles = search.results | where: 'object_type', "article"
                  assign search_articles_size = search_articles | size
                  assign search_pages = search.results | where: 'object_type', "page"
                  assign search_pages_size = search_pages | size
                %}

                {% if search_products_size != 0 %}
                    <div class="search-results__top first">
                      <h3 class="search-results__title subheading">
                        {{ 'templates.search.item_count.other' | t: count: '' }}
                      </h3>
                      <p class="search-results_count secondary_text">
                        {{ 'templates.search.item_count.other' | t: count: search_products_size }}
                      </p>
                    </div>
                    <ul class="collection-results collection-product-list 
                      collection-product-list--{{ section.settings.columns_mobile }}-mobile" role="list">
                      {%- for item in search_products -%}
                        <li class="collection-product-card template-search__item {% if settings.quickview_hover %}quickview--hover{% endif %}">
                          {% render 'product-card',
                            product_card_product: item,
                            media_size: section.settings.image_ratio,
                            media_fit: section.settings.image_fit,
                            show_secondary_image: section.settings.show_secondary_image,
                            show_vendor: section.settings.show_vendor,
                            show_collection: section.settings.show_collection,
                            show_desc: section.settings.show_desc
                          %}
                        </li>
                      {%- endfor -%}
                    </ul>
                {% endif %}

                {% if search_articles_size != 0 %}
                  <div class="search-results__top {% if search_products_size == 0 %} first {% endif %}">
                    <h3 class="search-results__title subheading">
                      {{ 'templates.search.article_count.other' | t: count: '' }}
                    </h3>
                    <p class="search-results_count secondary_text">
                        {{ 'templates.search.article_count.other' | t: count: search_articles_size }}
                      </p>
                  </div>
                  <ul
                    class="collection-results collection-results_articles collection-results_articles--{{ section.settings.columns_mobile }}-mobile collection-results_no-filter"
                    role="list"
                    style="--aspect-ratio: {{ section.settings.blog_image_ratio }};"
                  >
                    {%- for item in search_articles -%}
                      {%- case item.object_type -%}
                        {%- when 'article' -%}
                          <li class="template-search__item article">
                            {% render 'article-card',
                              article: item,
                              layout: section.settings.content_layout,
                              show_image: section.settings.article_show_image,
                              show_tags: section.settings.article_show_tags,
                              show_date: section.settings.article_show_date,
                              show_author: section.settings.article_show_author,
                              show_excerpt: section.settings.article_show_desc,
                            %}
                          </li>
                      {%- endcase -%}
                    {%- endfor -%}
                  </ul>
                {% endif %}
      
                {% if search_pages_size != 0 %}
                  <div class="search-results__top {% if search_products_size == 0 and search_articles_size == 0 %} first {% endif %}">
                    <h3 class="search-results__title subheading">
                      {{ 'templates.search.page_count.other' | t: count: '' }}
                    </h3>
                    <p class="search-results_count secondary_text">
                        {{ 'templates.search.page_count.other' | t: count: search_pages_size }}
                      </p>
                  </div>
                  <ul
                    class="collection-results collection-results-pages collection-results-pages--{{ section.settings.columns_mobile }}-mobile collection-results_no-filter" 
                    role="list"
                    style="--aspect-ratio: {{ section.settings.page_image_ratio }};"
                  >
                    {%- for item in search_pages -%}
                      {%- case item.object_type -%}
                        {%- when 'page' -%}
                          <li class="template-search__item template-search__page">
                            <a
                              href="{{ item.url }}"
                              class="card-page__wrapper"
                              aria-label="{{ item.title | truncate: 50 | escape }}"
                            >
                              <div class="card-page">
                                <span class="icon-wrapper">
                                  {% render 'icon-page' %}
                                </span>
                                <div class="card-page__content">
                                  <h3 class="card-page__title">
                                    {{ item.title | truncate: 50 | escape }}
                                  </h3>
                                </div>
                              </div>
                            </a>
                          </li>
                      {%- endcase -%}
                    {%- endfor -%}
                  </ul>
                {% endif %}
                {%- if paginate.pages > 1 -%}
                  {% render 'pagination', paginate: paginate %}
                {%- endif -%}
              </div>
          {%- endif -%}
        {% endpaginate %}
        </div>
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",
  "class": "section-search",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.main-search.settings.header__1.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        }
      ],
      "default": "3/4",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "t:sections.all.card.image_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.all.card.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection",
      "default": false,
      "label": "t:sections.all.card.show_collection.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.all.card.show_desc.info"
    },
    {
      "type": "header",
      "content": "t:sections.main-search.settings.header__2.content"
    },
    {
      "type": "select",
      "id": "blog_image_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        }
      ],
      "default": "16/9",
      "label": "t:sections.all.card.image_ratio.label"
    },
		{
			"type": "select",
			"id": "content_layout",
			"label": "t:sections.featured-blog.settings.content_layout.label",
			"default": "layout1",
			"options": [
				{
					"value": "layout1",
					"label": "t:sections.featured-blog.settings.content_layout.options__1.label"
				},
				{
					"value": "layout2",
					"label": "t:sections.featured-blog.settings.content_layout.options__2.label"
				},
				{
					"value": "layout3",
					"label": "t:sections.featured-blog.settings.content_layout.options__3.label"
				}
			]
		},
    {
      "type": "checkbox",
      "id": "article_show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label"
    },
    {
      "type": "checkbox",
      "id": "article_show_tags",
      "default": true,
      "label": "t:sections.main-search.settings.article_show_tags.label"
    },
    {
      "type": "checkbox",
      "id": "article_show_date",
      "default": true,
      "label": "t:sections.main-search.settings.article_show_date.label"
    },
    {
      "type": "checkbox",
      "id": "article_show_author",
      "default": true,
      "label": "t:sections.main-search.settings.article_show_author.label"
    },
    {
      "type": "checkbox",
      "id": "article_show_desc",
      "default": false,
      "label": "t:sections.main-search.settings.article_show_desc.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.image_filter.content"
    },
    {
      "type": "select",
      "id": "image_filter_ratio",
      "options": [
        {
          "value": "3/2",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "4/5",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        },
        {
          "value": "1/1",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        }
      ],
      "default": "4/5",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_filter_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label"
    },
    {
      "type": "range",
      "id": "image_filter_columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2,
      "label": "t:sections.main-collection-product-grid.settings.image_filter_columns.label"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header_mobile.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.main-collection-product-grid.settings.columns_mobile.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.main-collection-product-grid.settings.columns_mobile.options__2.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
  ]
}
{% endschema %}
