{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card-overlay.css' | asset_url | stylesheet_tag }}
{{ 'section-main-blog.css' | asset_url | stylesheet_tag }}
{%- if settings.pagination_type == 'load_more'
	or settings.pagination_type == 'infinite_scroll'
-%}
	<script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
	{% render 'section-margin' %}
{%- endstyle -%}

{% liquid
	assign slider_image_ratio = section.settings.slider_image_ratio | split: '/' | join: ''
%}

<div class="main-blog">
	<div class="container">
		<h1 class="main-blog__title title--page h2">
			{{ blog.title | escape }}
		</h1>
	</div>

	{% if section.blocks != blank and blog.articles_count > 0 %}
		{% render 'blog-slider',
			blocks: section.blocks,
			show_image: true,
			section_id: section.id,
			slideshow_speed: section.settings.slideshow_speed,
			autoplay: section.settings.is_autoplay,
			slideshow_delay: section.settings.slideshow_delay,
			stop_autoplay: section.settings.stop_autoplay,
			per_row: 1,
			color_scheme: section.settings.color_scheme,
			show_tags: section.settings.slider_show_tags,
			show_date: section.settings.slider_show_date,
			show_author: section.settings.slider_show_author,
			show_excerpt: section.settings.slider_show_excerpt,
			overlay_opacity: section.settings.overlay_opacity,
			image_ratio: section.settings.slider_image_ratio,
			slider_heading_size: section.settings.slider_heading_size,
			button_label: section.settings.button_label,
			button_style: section.settings.button_style,
			loop: section.settings.is_loop
		%}
	{% endif %}

	{% if blog.articles_count > 0 %}
		<div class="main-blog__articles container">
			{%- paginate blog.articles by section.settings.posts_per_page -%}
				<ul
					class="blog-articles load-more-grid blog-articles--{{ section.settings.columns_per_row}} blog-articles--{{ section.settings.columns_mobile }}-mobile"
					data-columns="{{ section.settings.columns_per_row }}"
				>
					{%- for article in blog.articles -%}
						{% comment %}{% liquid
							for block in section.blocks
								if block.settings.article.id == article.id
									assign exception = true
									break
								else
									assign exception = false
								endif
							endfor
							if exception
								continue
							endif
						%}{% endcomment %}

						{% style %}
							#shopify-section-{{ section.id }} [data-id="{{ article.id }}"].blog-articles__article {
							  {% if section.settings.image_ratio != 'adapt' %}
							    --aspect-ratio: {{ section.settings.image_ratio }};
							  {% elsif section.settings.image_ratio == 'adapt' and article.image != blank %}
							    --aspect-ratio: {{ article.image.aspect_ratio }};
							  {% else %}
							    --aspect-ratio: 16/9;
							  {% endif %}
							}
						{% endstyle %}
						<li
							class="blog-articles__article article"
							data-id="{{ article.id }}"
						>
							{%- render 'article-card',
								article: article,
								layout: section.settings.layout,
								show_image: section.settings.show_image,
								layout: section.settings.content_layout,
								show_tags: section.settings.show_tags,
								show_date: section.settings.show_date,
								show_author: section.settings.show_author,
								show_excerpt: section.settings.show_excerpt
							-%}
						</li>
					{%- endfor -%}
				</ul>

				{%- if paginate.pages > 1 -%}
					{%- if settings.pagination_type == 'load_more' -%}
						{% render 'load-more',
							next_url: paginate.next.url,
							count_pages: paginate.pages,
							current_page: paginate.current_page
						%}
						<div class="js-hidden">
							{% render 'pagination', paginate: paginate %}
						</div>
					{%- elsif settings.pagination_type == 'infinite_scroll' -%}
						{% render 'infinite-scroll',
							next_url: paginate.next.url,
							count_pages: paginate.pages,
							current_page: paginate.current_page
						%}
						<div class="js-hidden">
							{% render 'pagination', paginate: paginate %}
						</div>
					{% else %}
						{% render 'pagination', paginate: paginate %}
					{%- endif -%}
				{%- endif -%}
			{%- endpaginate -%}
		</div>
	{% endif %}
</div>

{% schema %}
{
	"name": "t:sections.main-blog.name",
	"tag": "section",
	"class": "section-main-blog spaced-section",
	"settings": [
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 12,
      "label": "t:sections.main-blog.settings.posts_per_page.label"
    },
		{
			"type": "range",
			"id": "columns_per_row",
			"min": 1,
			"max": 4,
			"step": 1,
			"default": 3,
			"label": "t:sections.all.columns.label"
