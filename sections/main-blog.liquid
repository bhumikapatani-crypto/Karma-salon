			"type": "select",
			"id": "content_layout",
			"label": "t:sections.featured-blog.settings.content_layout.label",
			"default": "layout3",
			"options": [
				{
					"value": "layout1",
					"label": "t:sections.featured-blog.settings.content_layout.options__1.label"
				},
				{
					"value": "layout2",
					"label": "t:sections.featured-blog.settings.content_layout.options__2.label"
				},
				{
					"value": "layout3",
					"label": "t:sections.featured-blog.settings.content_layout.options__3.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.mobile_options.header.content"
		},
		{
			"type": "select",
			"id": "columns_mobile",
			"default": "1",
			"label": "t:sections.all.mobile_options.columns.label",
			"options": [
				{
					"value": "1",
					"label": "t:sections.all.mobile_options.columns.options__1.label"
				},
				{
					"value": "2",
					"label": "t:sections.all.mobile_options.columns.options__2.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.slider_options.header.content",
			"info": "t:sections.main-blog.settings.slideshow.info__2"
		},
		{
			"type": "checkbox",
			"id": "is_loop",
			"default": true,
			"label": "t:sections.all.slider_options.slider_is_loop.label"
		},
		{
			"type": "checkbox",
			"id": "is_autoplay",
			"default": true,
