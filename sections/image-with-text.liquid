{{ 'section-image-with-text.css' | asset_url | stylesheet_tag }}
<script src="{{ 'image-with-text.js' | asset_url }}" defer="defer"></script>

{% style %}
	{% render 'section-margin' %}
{% endstyle %}

{% assign is_animated = section.settings.is_animated_heading %}

{% liquid
	assign is_heading = false
	if section.settings.heading != blank
		assign is_heading = true
	endif

	assign is_description = false
	if section.settings.text != blank
		assign is_description = true
	endif

	assign blocks_quantity = 0
	for block in section.blocks
		assign blocks_quantity = blocks_quantity | plus: 1
	endfor

	assign is_button = false
	if section.settings.button_label != blank
		assign is_button = true
	endif

	assign is_header_block = false
	if is_heading or is_description
		assign is_header_block = true
	endif

	assign is_right_block = false
	if is_header_block or blocks_quantity > 0 or is_button
		assign is_right_block = true
	endif
%}

<div class="image-with-text color-{{ section.settings.color_scheme }}" data-animation="{{ is_animated }}">
	<div class="container">
		<div class="image-with-text__wrapper promo-position-left">
			{% style %}
				#shopify-section-{{ section.id }} .image-with-text__wrapper {
					--aspect-ratio: {{ section.settings.image_ratio }};
				}
			{% endstyle %}
			<div class="image-with-text__promo {% if section.settings.image_parallax %}jarallax{% endif %}">
				<div class="image-with-text__promo-img {% if section.settings.image_parallax %}jarallax-img{% endif %}">
					{% if section.settings.image != blank and section.settings.video == blank %}
							{{ section.settings.image 
								| image_url: width: section.settings.image.width
								| image_tag: 
									loading: 'lazy',
									sizes: '100vw',
									widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
							}}
					{% elsif section.settings.video != blank %}
							{{ section.settings.video 
									| video_tag: loading: 'lazy',
															widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200',
															autoplay: true,
															class: 'data-alt',
															loop: true,
															controls: false,
															muted: true 
							}}
					{% else %}
							{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
					{% endif %}
				</div>
			</div>
			{% if is_right_block %}
				<div class="image-with-text__right-block">
					{% if is_header_block %}
						<div class="image-with-text__heading">
							{% if is_heading %}
								<div class="image-with-text__title h1">{{ section.settings.heading }}</div>
							{% endif %}
							{% if is_description %}
								<div class="image-with-text__description">{{ section.settings.text }}</div>
							{% endif %}
						</div>
					{% endif %}
					{% if blocks_quantity > 0 %}
						<div class="image-with-text__blocks{% if blocks_quantity == 1 %} one-block{% endif %}">
							{%- for block in section.blocks -%}
								<div class="image-with-text__card">
									{%- if block.settings.custom_icon != blank
										or block.settings.custom_icon_dm != blank 
										or block.settings.icon != 'none' 
									-%}
										<div class="image-with-text__card-img image-with-text__card-img--{{ section.settings.image_size }}">
											{%- if block.settings.custom_icon != blank
													or block.settings.custom_icon_dm != blank
												-%}
													{% if block.settings.custom_icon != blank %}
														{%- assign height = 24
															| divided_by: block.settings.custom_icon.aspect_ratio
															| round: 2
														-%}
														{{
															block.settings.custom_icon
															| image_url: width: 96
															| image_tag:
																width: 24,
																height: height,
																widths: '24, 48, 72, 96',
																class: 'collapsible-content__icon custom_icon'
														}}
													{% endif %}
													{% if block.settings.custom_icon_dm != blank %}
														{%- assign dm_height = 24
															| divided_by: block.settings.custom_icon_dm.aspect_ratio
															| round: 2
														-%}
														{{
															block.settings.custom_icon_dm
															| image_url: width: 96
															| image_tag:
																width: 24,
																height: dm_height,
																widths: '24, 48, 72, 96',
																class: 'collapsible-content__icon custom_icon--dm'
														}}
													{% endif %}
												{%- elsif block.settings.icon != 'none' -%}
													{% render 'icon-pack',
														icon: block.settings.icon
													%}
												{%- endif -%}
										</div>
									{%- endif -%}

									<div class="image-with-text__card__content-wrapper">
										<div class="image-with-text__card__info">
											{%- if block.settings.heading != blank -%}
												<h4 class="image-with-text__card__heading h3">
													{{ block.settings.heading | escape }}
												</h4>
											{%- endif -%}
											{%- if block.settings.text != blank -%}
												<div class="image-with-text__card__text richtext__content">
													{{ block.settings.text }}
												</div>
											{%- endif -%}
										</div>
									</div>
								</div>
							{%- endfor -%}
						</div>
					{% endif %}
					{% if is_button %}
						{% render 'button',
							btn_label: section.settings.button_label,
							btn_link: section.settings.button_link,
							btn_style: section.settings.button_style,
							add_classes: "image-with-text__button"
						%}
					{% endif %}
				</div>
			{% endif %}
		</div>
	</div>
</div>

