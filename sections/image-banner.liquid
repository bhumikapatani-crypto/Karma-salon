{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<script src="{{ 'image-banner.js' | asset_url }}" defer="defer"></script>

{% liquid
	assign image_ratio = section.settings.image_ratio
	assign is_animated = section.settings.is_animated_heading

	assign layout = section.settings.layout

	if image_ratio == 'adapt'
		if section.settings.image == blank
			assign aspect_ratio = 0
			assign padding_bottom = 0
		else
			assign aspect_ratio = section.settings.image.aspect_ratio
			assign padding_bottom = 'calc((100vw - var(--scrollbar-width, "0px")) / (var(--aspect_ratio)))'
		endif
	elsif image_ratio == 'large'
		assign padding_bottom = '100vh'
	else
		assign aspect_ratio = image_ratio
		assign padding_bottom = 'calc((100vw - var(--scrollbar-width, "0px")) / (var(--aspect_ratio)))'
	endif

	assign is_first_block = false
	if section.settings.heading != blank
		assign is_first_block = true
	endif

	assign is_second_block = false
	if section.settings.heading_2 != blank or section.settings.description != blank
		assign is_second_block = true
	endif
%}

{% style %}
	 {% render 'section-margin' %}

	 #shopify-section-{{ section.id }} .image-banner {
	   --aspect_ratio: {{ aspect_ratio }};
	 }

	 #shopify-section-{{ section.id }} .image-banner__overlay {
	   opacity: {{ section.settings.overlay_opacity }};
	 }

	#shopify-section-{{ section.id }} .image-banner__container {
		min-height: {{ padding_bottom }};
	}
{% endstyle %}

<div
	class="image-banner color-{{ section.settings.color_scheme }} overlay"
	data-animation="{{ is_animated }}"
>
	<div class="image-banner__container image-banner__container--{{ layout }}">
		<div class="image-banner__wrapper container">
			<div class="image-banner__media">
				{% liquid
					assign width_adapt_ratio = 1
					if section.settings.image.width > section.settings.image.height
						assign width_adapt_ratio = 550 | times: section.settings.image.aspect_ratio | round: 2
					endif

					assign desktop_width = 'calc(100vw - 64px * 2)'
				%}
				{% capture sizes %}
            (min-width: 1100px) {{ desktop_width }}, 
            {% if width_adapt_ratio != 1 %}
              {{ width_adapt_ratio }}px
            {% else %}
              100vw
            {% endif %}
          {% endcapture %}

				{% liquid
					assign image_loading = 'lazy'
					assign fetch_priority = 'auto'
					if section.index == 1
						assign image_loading = 'eager'
						assign fetch_priority = 'high'
					endif
				%}

				{%- if section.settings.image != blank
					and section.settings.video == blank
				-%}
					{{
						section.settings.image
						| image_url: width: section.settings.image.width
						| image_tag:
							loading: image_loading,
							fetchpriority: fetch_priority,
							sizes: sizes,
							widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
					}}
				{%- elsif section.settings.video != blank -%}
					{{
						section.settings.video
						| video_tag:
							image_size: '1920x',
							autoplay: true,
							loop: true,
							controls: false,
							muted: true,
							class: 'data-alt'
					}}
				{%- else %}
					{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
				{%- endif -%}
			</div>
			<span class="image-banner__overlay"></span>
			{% if is_first_block or is_second_block %}
				<div class="
						image-banner__content-wrapper image-banner__content-wrapper--content-{{ section.settings.content_position }}
						image-banner__content-wrapper--{{ layout }}{% if is_first_block == false or is_second_block == false %} no-after{% endif %}
					">
					{%- if is_first_block %}
						<div class="image-banner__content {% if section.settings.percent == blank %} image-banner__content--only-content{% endif %}">
							<h2
								class="image-banner__heading {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
								{% if settings.animations_reveal_on_scroll %}
									data-cascade
								{% endif %}
							>
								{{ section.settings.heading }}
							</h2>
						</div>
					{%- endif -%}
					{% if is_second_block %}
						<div class="image-banner__promo">
							{% if section.settings.heading_2 != blank %}
								<h2
									class="image-banner__promo--heading h0{% if is_animated %} animated-heading{% elsif settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
									data-speed="{{ section.settings.heading_animation_speed }}"
									{% if settings.animations_reveal_on_scroll
										and is_animated == false
									%}
										data-cascade
									{% endif %}
									data-animated_text="{{ section.settings.heading_2 }}"
								>
									<span
										class="image-banner__promo--heading--inner{% if is_animated %} animated-heading--inner{% endif %}"
										{% if is_animated %}
											style="opacity: 0;"
										{% endif %}
									>
										{{- section.settings.heading_2 -}}
									</span>
								</h2>
							{% endif %}
							{% if section.settings.description != blank %}
								<div
									class="image-banner__promo--description{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
									{% if settings.animations_reveal_on_scroll %}
										data-cascade
									{% endif %}
								>
									{{ section.settings.description }}
								</div>
							{% endif %}
						</div>
					{% endif %}
				</div>
			{% endif %}
			{% if section.settings.button_label != blank %}
				{% assign button_label = section.settings.button_label %}
				{% assign btn_classes = 'image-banner__button focus-inset' %}
				{% if settings.animations_reveal_on_scroll %}
					{% assign btn_classes = btn_classes
						| append: ' scroll-trigger animate--slide-in-text'
					%}
				{% endif %}

				{% render 'button',
					btn_label: button_label,
					btn_link: section.settings.button_link,
					btn_style: section.settings.button_style,
					add_classes: btn_classes,
					data-cascade: true
				%}
			{% endif %}
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.image-banner.name",
	"tag": "section",
	"class": "image-banner-section spaced-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-2",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.image.header.content"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.all.image.label"
		},
		{
			"type": "video",
			"id": "video",
			"label": "t:sections.all.video.label",
			"info": "t:sections.all.video.info"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"default": "large",
			"label": "t:sections.all.image.aspect_ratio.label",
			"options": [
				{
					"value": "1/1",
					"label": "t:sections.all.image.aspect_ratio.options__1.label"
				},
				{
					"value": "3/2",
					"label": "t:sections.all.image.aspect_ratio.options__2.label"
				},
				{
					"value": "3/4",
					"label": "t:sections.all.image.aspect_ratio.options__3.label"
				},
				{
					"value": "4/3",
					"label": "t:sections.all.image.aspect_ratio.options__4.label"
				},
				{
					"value": "16/9",
					"label": "t:sections.all.image.aspect_ratio.options__5.label"
				},
				{
					"value": "21/9",
					"label": "t:sections.all.image.aspect_ratio.options__6.label"
				},
				{
					"value": "adapt",
					"label": "t:sections.all.image.aspect_ratio.options__7.label"
				},
				{
					"value": "large",
					"label": "t:sections.all.image.aspect_ratio.options__8.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.overlay.header.content"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"min": 0,
			"max": 1,
			"step": 0.1,
			"default": 0.4,
			"label": "t:sections.all.overlay.overlay_opacity.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.content_options.header.content"
		},
		{
			"type": "select",
			"id": "layout",
			"default": "row",
			"label": "t:sections.image-banner.settings.content_layout.label",
			"options": [
				{
					"value": "row",
					"label": "t:sections.image-banner.settings.content_layout.options.options__1.label"
				},
				{
					"value": "column",
					"label": "t:sections.image-banner.settings.content_layout.options.options__2.label"
				},
				{
					"value": "bottom middle",
					"label": "t:sections.image-banner.settings.content_layout.options.options__5.label"
				},
				{
					"value": "left",
					"label": "t:sections.image-banner.settings.content_layout.options.options__3.label"
				},
				{
					"value": "bottom",
					"label": "t:sections.image-banner.settings.content_layout.options.options__4.label"
				}
			]
		},
		{
			"type": "select",
			"id": "content_position",
			"default": "left",
			"label": "t:sections.all.content_position.label_secondary",
			"options": [
				{
					"value": "left",
					"label": "t:sections.all.content_position.options.options__3.label"
				},
				{
					"value": "right",
					"label": "t:sections.all.content_position.options.options__4.label"
				}
			]
		},
		{
			"type": "text",
			"id": "heading",
			"label": "t:sections.all.heading.label",
			"default": "t:sections.image-banner.settings.heading.default"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h2",
			"label": "t:sections.all.heading_size.label"
		},
		{
			"type": "text",
			"id": "heading_2",
			"label": "t:sections.all.heading.label__22",
			"default": "t:sections.image-banner.settings.heading_2.default"
		},
		{
			"type": "richtext",
			"id": "description",
			"label": "t:sections.all.text.label",
			"default": "t:sections.image-banner.settings.text.default"
		},
		{
			"type": "header",
			"content": "t:sections.image-banner.settings.heading_animation.label"
		},
		{
			"type": "checkbox",
			"id": "is_animated_heading",
			"default": true,
			"label": "t:sections.image-banner.settings.enable_heading_animation.label__2"
		},
		{
			"type": "range",
			"id": "heading_animation_speed",
			"min": 50,
			"max": 300,
			"step": 50,
			"label": "t:sections.image-banner.settings.heading_animation_speed.label",
			"default": 150
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.all.button.button_label.default_2",
			"label": "t:sections.all.button.button_label.label",
			"info": "t:sections.image-banner.settings.button_label.info"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:sections.all.button.button_link.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				}
			],
			"default": "secondary",
			"label": "t:sections.all.button.button_style.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.image-banner.presets.name"
		}
	]
}
{% endschema %}
