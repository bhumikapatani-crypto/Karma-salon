{{ 'section-card-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'card-grid.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

{% liquid
  assign indent_value = '2.4rem'
  assign swipe_on_mobile = section.settings.swipe_on_mobile
  assign columns_per_row = section.settings.columns_per_row
  assign image_ratio = section.settings.image_ratio
%}

<div class="simple-card-grid">
  <div class="container">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag,
      section_description: section.settings.section_description,
      section_heading_size: section.settings.section_heading_size,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}
  </div>
  <div class="simple-card-grid__container{% if section.settings.layout == "simple" %} container {% endif %}">
    <div class="simple-card-grid__wrapper">
      <div class="simple-card-grid-list {% if swipe_on_mobile and section.blocks.size > 1 %}swiper swiper--card-grid{% endif %}">
        <div
          class="simple-card-grid-list__wrapper simple-card-grid-list__wrapper--{{ columns_per_row }} simple-card-grid-list__wrapper--{{ section.settings.layout }} simple-card-grid-list__wrapper--{{ section.settings.columns_mobile }}-mobile {% if swipe_on_mobile and section.blocks.size > 1 %} swiper-wrapper{% endif %}"
          style="--indent_value: {{ indent_value }};"
        >
          {%- for block in section.blocks -%}
            {% style %}
              #shopify-section-{{ section.id }} [data-id="{{ block.id }}"] .simple-card-grid-card__image {
                  {% if image_ratio != 'adapt' %}
                    --aspect-ratio: {{ image_ratio }};
                  {% elsif image_ratio == 'adapt' %}
                    {% if block.settings.image != blank and block.settings.video == blank %}
                      --aspect-ratio: {{ block.settings.image.aspect_ratio }};
                    {% elsif block.settings.video != blank %}
                      --aspect-ratio: {{ block.settings.video.aspect_ratio }};
                    {%  else %}
                      --aspect-ratio: 1/1;
                    {% endif %}
                  {% else %}
                    --aspect-ratio: {{ section.settings.aspect_ratio }};
                  {% endif %}
                }
            {% endstyle %}
            {% liquid
              assign withoutBorderRadius = false
              if indent_value == '0' and section.blocks.size > 1
                assign withoutBorderRadius = true
              endif
            %}
            <div
              class="
                simple-card-grid-card simple-card-grid-card--left
                {% if swipe_on_mobile and section.blocks.size > 1 %}swiper-slide{% endif %}{% if withoutBorderRadius %} without-border-radius{% endif %}
                {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
                {% if section.settings.layout == "overlay" %}  color-{{ block.settings.color_scheme }}{% endif %}
              "
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
              {% endif %}
              data-id="{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.primary_button_link != blank -%}
                <a
                  href="{{ block.settings.primary_button_link }}"
                  class="simple-card-grid-card__link-overlay"
                  aria-label="{{ block.settings.primary_button_label }}"
                ></a>
              {%- endif -%}
              {%- capture sizes -%}
                  (min-width: 1100px) calc((100vw - 64px * 2)), calc((100vw - 20px * 2))
                {%- endcapture -%}
              <div class="simple-card-grid-card__image {{ image_ratio }}">
                {%- if block.settings.image != blank and block.settings.video == blank -%}
                  {{
                    block.settings.image
                    | image_url: width: block.settings.image.width
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.image.width,
                      height: block.settings.image.height,
                      sizes: sizes,
                      widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200'
                  }}
                {% elsif block.settings.video != blank %}
                  {{
                    block.settings.video
                    | video_tag:
                      loading: 'lazy',
                      class: 'data-alt',
                      widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200',
                      autoplay: true,
                      loop: true,
                      controls: false,
                      muted: true
                  }}
                {% else %}
                  {% assign cycle_index = forloop.index | modulo: 3 | plus: 1 %}
                  {% assign svg_placeholder_name = 'hero-apparel-' | append: cycle_index %}
                  {{ svg_placeholder_name | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}

                {% if section.settings.layout == 'overlay' %}
                  {%- if block.settings.heading != blank or block.settings.text != blank -%}
                    <div
                      class="simple-card-grid-card__wrapper overlay"
                      {%- if block.settings.overlay_opacity != blank and section.settings.layout == 'overlay' -%}
                        style="--overlay-opacity: {{ block.settings.overlay_opacity }}"
                      {%- endif -%}
                    >
                      <div class="simple-card-grid-card__content">
                        <div class="simple-card-grid-card__info">
                          {%- if block.settings.heading != blank -%}
                            <{{ block.settings.heading_tag_second }} class="simple-card-grid-card__heading {{section.settings.heading_size }}">
                              {{ block.settings.heading | escape }}
                            </{{ block.settings.heading_tag_second }}>
                          {%- endif -%}
                          {%- if block.settings.text != blank -%}
                            <div class="simple-card-grid-card__text richtext__content">
                              {{ block.settings.text }}
                            </div>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  {% endif %}
                {% endif %}
              </div>
              {% if section.settings.layout == 'simple' %}
                {%- if block.settings.heading != blank or block.settings.text != blank -%}
                  <div class="simple-card-grid-card__wrapper simple">
                    <div class="simple-card-grid-card__content">
                      <div class="simple-card-grid-card__info">
                        {%- if block.settings.heading != blank -%}
                          <{{ block.settings.heading_tag_second }} class="simple-card-grid-card__heading {{section.settings.heading_size }}">
                            {{ block.settings.heading | escape }}
                          </{{ block.settings.heading_tag_second }}>
                        {%- endif -%}
                        {%- if block.settings.text != blank -%}
                          <div class="simple-card-grid-card__text richtext__content">
                            {{ block.settings.text }}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endif %}
            </div>
          {%- endfor -%}
        </div>

        {%- if swipe_on_mobile and section.blocks.size > 1 -%}
          <div class="swipe-on-mobile__nav no-js-hidden">
            <div class="simple-card-grid__pagination swiper-pagination"></div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.card-grid.name",
  "class": "card-grid-section spaced-section",
  "tag": "section",
  "max_blocks": 12,
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "t:sections.all.columns.label",
      "info": "t:sections.all.columns.info"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "simple",
          "label": "t:sections.all.layout.options.options__3.label"
        },
        {
          "value": "overlay",
          "label": "t:sections.all.layout.options.options__4.label"
        }
      ],
      "default": "overlay",
      "label": "t:sections.all.layout.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.card-grid.settings.cards_heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": false,
      "label": "t:sections.all.mobile_options.swipe.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.image.header.content__1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "5/4",
      "label": "t:sections.all.image.aspect_ratio.label",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "5/4",
          "label": "t:sections.all.image.aspect_ratio.options__9.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.image.aspect_ratio.options__7.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading.label__tag",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "section_description",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "section_button_label",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "section_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "card-grid_card",
      "name": "t:sections.card-grid.blocks.card-grid_card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.all.video.label",
          "info": "t:sections.all.video.info"
        },
        {
          "type": "header",
          "content": "t:sections.card-grid.blocks.overlay_options.label"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "background-2",
          "label": "t:sections.all.color_scheme.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "default": 0.1,
          "label": "t:sections.all.overlay.overlay_opacity.label_secondary"
        },
        {
          "type": "header",
          "content": "t:sections.all.content_options.header.content"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "t:sections.card-grid.blocks.heading.default",
          "label": "t:sections.all.heading.label"
        },
        {
          "type": "select",
          "id": "heading_tag_second",
          "options": [
            {
              "value": "h1",
              "label": "t:sections.all.heading_tag.options__1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_tag.options__2.label"
            },
            {
              "value": "h3",
              "label": "t:sections.all.heading_tag.options__3.label"
            },
            {
              "value": "h4",
              "label": "t:sections.all.heading_tag.options__4.label"
            },
            {
              "value": "h5",
              "label": "t:sections.all.heading_tag.options__5.label"
            },
            {
              "value": "h6",
              "label": "t:sections.all.heading_tag.options__6.label"
            },
            {
              "value": "div",
              "label": "t:sections.all.heading_tag.options__7.label"
            },
            {
              "value": "p",
              "label": "t:sections.all.heading_tag.options__8.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading.label__tag",
          "info": "t:sections.all.heading_tag.info"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:sections.all.text.label"
        },
        {
          "type": "url",
          "id": "primary_button_link",
          "label": "t:sections.all.overlay_link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.card-grid.name",
      "blocks": [
        {
          "type": "card-grid_card"
        },
        {
          "type": "card-grid_card"
        }
      ]
    }
  ]
}
{% endschema %}
