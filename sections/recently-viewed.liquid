{{ 'section-popular-products.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>
<script src="{{ 'recently-viewed.js' | asset_url }}" defer="defer"></script>

{%- if settings.quickview_show == false and settings.type_color_swatch == 'custom' -%}
	{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{% endif %}

{%- style -%}
	{% render 'section-margin' %}
	{% render 'section-padding' %}

	.popular-products__wrapper {
		position: relative;
	}
	.recently-viewed__empty {
		display: none;
		width: 100%;
		align-items: center;
		justify-content: center;
		margin: 3rem 0 1rem;
	}
	.recently-viewed__empty span {
		max-width: 550px;
		text-align: center;
	}
	.recently-viewed--empty .recently-viewed__empty {
		display: flex;
	}
	.recently-viewed .loading-overlay {
		inset: 0;
		z-index: 6;
		display: none;
		width: 100%;
		padding: 0 5rem;
	}
	.recently-viewed.recently-viewed--loading .loading-overlay {
		display: block;
	}
	.recently-viewed.recently-viewed--loading .loading-overlay .loading-overlay__spinner {
		top: 50%;
		transform: translateY(-50%);
	}
	.section-{{ section.id }}-padding .popular-products__wrapper {
		gap: 2.4rem;
	}
	.recently-viewed.recently-viewed--loading .popular-products__navigation,
	.recently-viewed.recently-viewed--empty .popular-products__navigation {
		display: none;
	}
	.recently-viewed:not(.recently-viewed--empty):not(.recently-viewed--loading) .recently-viewed__empty {
		display: none;
	}
{%- endstyle -%}

{%- if settings.quickview_show or settings.add_to_cart_enabled -%}
	<link
		rel="preload"
		href="{{ 'section-main-product.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>
	<link
		rel="stylesheet"
		href="{{ 'component-deferred-media.css' | asset_url }}"
		media="all"
	>
	<link
		rel="preload"
		href="{{ 'quick-add.css' | asset_url }}"
		as="style"
		onload="this.onload=null;this.rel='stylesheet'"
	>

	<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
	<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% assign section_id = 'shopify-section-' | append: section.id %}
{% liquid
	paginate search.results by 50
		assign product_list = search.results | where: 'object_type', 'product'
	endpaginate
	assign product_count = 0

	for product in product_list
		assign product_count = product_count | plus: 1
	endfor

	assign has_products = false
	if product_list.size > 0
		assign has_products = true
	endif

	assign columns = section.settings.product_limit
%}
<div
	id="{{ section_id }}"
	class="popular-products section-{{ section.id }}-padding recently-viewed recently-viewed--loading
	{% if section.settings.enable_border_top %} section_border_top{% endif %}
	{% if section.settings.enable_border_bottom %} section_border_bottom{% endif %}
	{% if search.performed %} recently-viewed--search-perfomed{% endif %}
	{% if has_products %} recently-viewed--has-products{% endif %}"
	data-base-url="{{ routes.search_url }}?section_id={{ section.id }}&type=product"
	data-products-limit="{{ section.settings.products_limit }}"
	data-expiration-days="{{ settings.recently_product_record_lifetime }}"
	{% if request.design_mode %}data-edit-mode="true"{% endif %}
	{% if request.page_type == 'product' and product != blank %}
		data-current-page-product-id="{{ product.id }}"
	{% endif %}
>
	<div class="container">
		{% render 'section-header',
			section_heading: section.settings.heading,
			section_description: section.settings.description,
			button_label: section.settings.button_label,
			button_link: section.settings.button_link,
			button_style: section.settings.button_style
		%}
		<div class="loading-overlay">
			<div class="loading-overlay__spinner">
				{% render 'icon-spinner' %}
			</div>
		</div>

		{% if product_list.size == 0 %}
			<div class="recently-viewed__empty body-large">
				<span class="body-large">{{- 'sections.recently_viewed.empty_message' | t -}}</span>
			</div>
		{% endif %}
		<div class="popular-products__wrapper popular-products__wrapper--{{ columns }} popular-products__wrapper--{{ section.settings.columns_mobile }}-mobile">
			{% for product in product_list %}
				{% liquid
					assign media_size_value = section.settings.image_ratio
					if section.settings.image_ratio == 'landscape'
						assign media_size_value = '3/2'
					elsif section.settings.image_ratio == 'portrait'
						assign media_size_value = '3/4'
					elsif section.settings.image_ratio == 'square'
						assign media_size_value = '1/1'
					endif
				%}
				<div class="popular-products__item border-item">
					{% render 'product-card',
						product_card_product: product,
						media_size: media_size_value,
						media_fit: section.settings.image_fit,
						show_secondary_image: section.settings.show_secondary_image,
						show_vendor: section.settings.show_vendor,
						show_desc: section.settings.show_desc,
						show_color_swatch: section.settings.show_color_swatch,
						show_collection: section.settings.show_collection_name,
						section_id: section.id,
						show_sku: section.settings.show_sku,
						add_id: forloop.index
					%}
				</div>
			{% endfor %}
		</div>
	</div>
</div>

{% schema %}
{
