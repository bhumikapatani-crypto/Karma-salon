{{ 'section-product-markers.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-padding' %}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  assign aspect_ratio = section.settings.media_ratio | split: '/'
  assign padding_bottom = aspect_ratio[1] | divided_by: aspect_ratio[0] | times: 100 | round: 0

  assign is_animated = section.settings.heading_animation

  if aspect_ratio != 'adapt' and section.settings.image != blank
    assign img = section.settings.image
    assign padding_bottom = img.width | divided_by: img.height | times: 100 | append: '%'
  elsif aspect_ratio == 'adapt'
    assign padding_bottom = '44%'
  endif
%}

<div
  class="
    product-markers product-markers--{{ section.settings.layout }} color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding
    {% if section.settings.heading_notebook_bg and section.settings.layout == "column" %} notebook-bg{% endif %}
  "
  data-animation="{{ is_animated }}"
>
  {% if section.settings.layout == 'row' %}
    <div class="container">
  {% endif %}

  <div class="product-markers__header">
    {% if section.settings.section_heading1 != blank %}
      <{{ section.settings.heading_tag }}
        class="product-markers__title h0 {% if is_animated %} animated-heading{% endif %}"
        data-speed="{{ section.settings.heading_animation_speed }}"
        data-animated_text="{{ section.settings.section_heading1 }}"
      >
        <span
          class="{% if is_animated %} animated-heading--inner{% endif %}"
          {% if is_animated %}
            style="opacity: 0;"
          {% endif %}
        >
          {{- section.settings.section_heading1 -}}
        </span>
      </{{ section.settings.heading_tag }}>
    {% endif %}
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag_second,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}
  </div>

  {% if section.settings.layout == 'row' %}
    </div>
  {% endif %}
  <div class="content product-markers__content">
    {% for block in section.blocks %}
      <div
        data-index="{{ forloop.index }}"
        class="product-markers__item-inner product-markers__item-inner__upper {% if forloop.first %} active {% endif %} color-{{ section.settings.card_color_scheme }} js-product-markers__item-inner product-markers__item-inner--{{ block.settings.tooltip_open_position }} {% if block.settings.product_id != blank %}collection-product-card {% endif %}"
      >
        {% render 'product-card-horizontal',
          product_card_product: block.settings.product_id,
          media_size: section.settings.image_ratio,
          color_scheme: section.settings.card_color_scheme,
          media_fit: section.settings.image_fit,
          show_secondary_image: section.settings.show_secondary_image,
          show_vendor: section.settings.show_vendor,
          btn_style: section.settings.button_style,
          section_id: section.id,
          show_button: section.settings.show_button
        %}
      </div>
    {% endfor %}

    <div class="product-markers__markers product-markers__markers--{{ section.settings.layout }} product-markers__markers--none product-markers__markers--{{ aspect_ratio }}">
      {%- for block in section.blocks -%}
        <div
          data-index="{{ forloop.index }}"
          class="product-markers__item js-product-markers__item color-background-2 {% if forloop.first %} active {% endif %} focus-inset"
          {{ block.shopify_attributes }}
          style="                --top: {{ block.settings.position_y }}%; --left:{{ block.settings.position_x }}%;"
          tabindex="0"
          role="button"
          aria-label="Open product card for {{ block.settings.product_id }}"
        >
          <div class="product-markers__item-number standard focus-inset">
            {% render 'icon-pack-markers', icon: 'standard' %}
          </div>
          <div
            data-index="{{ forloop.index }}"
            class="
              product-markers__item-inner color-{{ section.settings.card_color_scheme }}
              {% if section.settings.show_button == false %} no-button{% endif %}
              js-product-markers__item-inner product-markers__item-inner--{{ block.settings.tooltip_open_position }}
              {% if block.settings.product_id != blank %}collection-product-card {% endif %}
            "
          >
            {% render 'product-card-horizontal',
              product_card_product: block.settings.product_id,
              media_size: section.settings.image_ratio,
              color_scheme: section.settings.card_color_scheme,
              media_fit: section.settings.image_fit,
              show_secondary_image: section.settings.show_secondary_image,
              show_vendor: section.settings.show_vendor,
              btn_style: section.settings.button_style,
              section_id: section.id,
              show_button: section.settings.show_button
            %}
          </div>
        </div>
      {% endfor %}

      {% liquid
        if section.settings.image != blank
          assign image = section.settings.image
        elsif section.settings.image
          assign image = blank
        endif
      %}

      {% if image != blank %}
        {% capture sizes %}
            {% if section.settings.layout == 'column' %}
              (min-width: 1100px) calc(50vw - 20px),
            {% else %}
              (min-width: 1100px) calc(100vw - 40px),
            {% endif %}
            calc(100vw - 40px)
          {% endcapture %}
        {{
          image
          | image_url: width: image.width
          | image_tag:
            widths: '360, 425, 576, 768, 900, 1100, 1440, 1840',
            sizes: sizes,
            class: 'product-markers__image'
        }}
      {% else %}
        {{ 'collection-apparel-1' | placeholder_svg_tag: 'product-markers__placeholder-svg placeholder-svg' }}
      {% endif %}
      {% style %}
        #shopify-section-{{ section.id }} .product-markers__markers {
          padding-bottom: {{ padding_bottom }}%;
        }
      {% endstyle %}
    </div>
  </div>
</div>

<script src="{{ 'product-markers.js' | asset_url }}" defer="defer"></script>

