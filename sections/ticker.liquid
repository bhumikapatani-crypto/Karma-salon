{{ 'section-ticker.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
  {% render 'section-padding' %}
{%- endstyle -%}

<div class="ticker section-{{ section.id }}-padding{% if section.settings.notebook_bg %} notebook-bg{% endif %} color-{{ section.settings.color_scheme }} {% if section.settings.ticker_pause_hover %} ticker--pause-hover{% endif %} ticker--{{ section.settings.ticker_direction }}">
  {% liquid
    if section.settings.text_size == 'h2'
      assign initial_value_symbols = 160
    elsif section.settings.text_size == 'h3'
      assign initial_value_symbols = 200
    elsif section.settings.text_size == 'h4'
      assign initial_value_symbols = 250
    else
      assign initial_value_symbols = 128
    endif

    assign ticker_elements_count = section.blocks.size

    assign min_duration = 20
    assign max_duration = 100
    assign speed = section.settings.ticker_speed
    assign speed_range = 200
    assign duration_range = max_duration | minus: min_duration
    assign duration_temp = speed | times: duration_range | divided_by: speed_range
    assign duration = max_duration | minus: duration_temp

    assign image_loading = 'lazy'
    assign fetch_priority = 'auto'
    if section.index == 1
      assign image_loading = 'eager'
      assign fetch_priority = 'high'
    endif
  %}

  <div
    class="ticker__wrapper ticker__wrapper--{{ section.settings.default_padding }}"
    style="--ticker-duration: {{ duration }}s;"
  >

    {%- capture ticker_line -%}
      {% for block in section.blocks %}
        <div class="ticker__block{% if block.settings.ticker_text != blank %} ticker__block-with_text{% endif %}">
          {%- if block.settings.custom_icon != blank
						or block.settings.custom_icon_dm != blank
						or block.settings.icon != 'none'
					-%}
            <div class="ticker__image-wrapper ticker__image-wrapper--{{ section.settings.image_size }}">
              {%- if block.settings.custom_icon != blank
                or block.settings.custom_icon_dm != blank
              -%}
                {% if block.settings.custom_icon != blank %}
                  {%- assign height = 24
                    | divided_by: block.settings.custom_icon.aspect_ratio
                    | round: 2
                  -%}
                  {{
                    block.settings.custom_icon
                    | image_url: width: 96
                    | image_tag:
                      width: 24,
                      height: height,
                      widths: '24, 48, 72, 96',
                      class: 'ticker__image custom_icon'
                  }}
                {% endif %}
                {% if block.settings.custom_icon_dm != blank %}
                  {%- assign dm_height = 24
                    | divided_by: block.settings.custom_icon_dm.aspect_ratio
                    | round: 2
                  -%}
                  {{
                    block.settings.custom_icon_dm
                    | image_url: width: 96
                    | image_tag:
                      width: 24,
                      height: dm_height,
                      widths: '24, 48, 72, 96',
                      class: 'ticker__image custom_icon--dm'
                  }}
                {% endif %}
              {%- elsif block.settings.icon != 'none' -%}
                {% render 'icon-pack',
                  icon: block.settings.icon
                %}
              {%- endif -%}
            </div>
          {%- endif -%}
          {% if block.settings.ticker_heading != blank or block.settings.ticker_text != blank %}
            <div class="ticker__text-content">
              {% if block.settings.ticker_heading != blank %}
                <span class="ticker__text {{ section.settings.text_size }} richtext-link-inside">
                  {{- block.settings.ticker_heading -}}
                </span>
              {% endif %}
              {% if block.settings.ticker_text != blank %}
                <span class="ticker__descr richtext-link-inside secondary_text">
                  {{- block.settings.ticker_text -}}
                </span>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    {%- endcapture -%}

    <div
      class="ticker__line ticker__line--spacer"
      style="visibility: hidden;opacity: 0;position: static;"
    >
      {{ ticker_line }}
    </div>

    <div class="ticker__line{% if speed == 0 %} ticker__line--stopped{% endif %}">
      {%- for i in (1..ticker_elements_count) -%}
        {{ ticker_line }}
      {%- endfor -%}
    </div>

    <div class="ticker__line ticker__line--second{% if speed == 0 %} ticker__line--hidden{% endif %}">
      {%- for i in (1..ticker_elements_count) -%}
        {{ ticker_line }}
      {%- endfor -%}
    </div>
  </div>
</div>

