{{ 'section-testimonials.css' | asset_url | stylesheet_tag }}
<script src="{{ 'testimonials.js' | asset_url }}" defer="defer"></script>


{% liquid
  assign slides_quantity = section.blocks.size
  assign color_scheme = section.settings.color_scheme
  assign image_size = section.settings.image_size
  assign autoplay = section.settings.is_autoplay
  assign loop = section.settings.is_loop
  assign stop_autoplay = section.settings.is_hover_stop_autoplay
  assign slideshow_speed = section.settings.slideshow_speed
  assign slideshow_delay = section.settings.slideshow_delay
  assign slider_type = section.settings.slider_type
  assign second_infinite = false
  if slider_type == "infinite" 
    if slides_quantity > 2
      assign second_infinite = true
    endif
  endif

  assign third_infinite = false
  if slider_type == "infinite" 
    if slides_quantity == 3
      assign third_infinite = true
    endif
  endif
%}

{%- style -%}
  {% render 'section-margin' %}

  :root {
    --speed: {{ slideshow_speed }}s;
    --slides_quantity: {{ slides_quantity }};
    --delay: {{ slideshow_delay }}s;
  }
{%- endstyle -%}

<div
  class="testimonials"
  data-id="shopify-section-{{ section.id }}"
  data-autoplay="{{ autoplay }}"
  data-stop-autoplay="{{ stop_autoplay }}"
  data-speed="{{ slideshow_speed }}"
  data-delay="{{ slideshow_delay }}"
  data-loop="{{ loop }}"
  data-slider-type="{{ slider_type }}"
  style="--speed: {{ slideshow_speed }}s;
    --slides_quantity: {{ slides_quantity }};
    --delay: {{ slideshow_delay }}s;"
>
  <div class="testimonials__wrapper">
    <div class="testimonials__grid">
      {% if image_size != 'adapt' and image_size != 'large' %}
        {% style %}
          #shopify-section-{{ section.id }} .testimonials__media {
            aspect-ratio: {{ image_size }};
          }
        {% endstyle %}
      {% endif %}
      <div class="testimonials__content container">
        <div class="testimonials__static-info">
          {%- if section.settings.heading != blank -%}
            <h2 class="testimonials__heading {{ section.settings.heading_size }}">
              {{ section.settings.heading }}
            </h2>
          {%- endif -%}
          {% if section.settings.text != blank %}
            <div class="testimonials__text richtext__content">
              {{ section.settings.text }}
            </div>
          {% endif %}
        </div>

        {% if slider_type == "infinite" %}
          <div class="testimonials__swiper-container{% if section.settings.gradient %} gradient{% endif %}">
        {% endif %}
          <div class="testimonials__swiper testimonials__swiper--{{slides_quantity}} {% if slider_type == "swiper" %} swiper{% elsif stop_autoplay %} stopmotion-onhover{% endif %}" mouseenter="stopAutoplay">
            <div class="testimonials__swiper-wrapper swiper-wrapper">
              {%- for block in section.blocks -%}
                {% liquid 
                  assign author_block = false 
                  if block.settings.author_image != blank or block.settings.author_name != blank
                    assign author_block = true
                  endif
                %}
                <div
                  class="testimonials__slide focus-inset testimonials__slide--{{ slider_type }} swiper-slide  color-{{ color_scheme }}{% if section.settings.notebook %} notebook-bg{% endif %}"
                  {{ block.shopify_attributes }}
                  tabindex="0"
                >
                  <div class="testimonials__image">
                    {%- if block.settings.image != blank -%}
                      {%- assign widths = '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200' -%}
                      {%- capture sizes -%}
                        (min-width: 1100px) calc((100vw - 128px)), calc((100vw - 40px))
                      {%- endcapture -%}
                      {{
                        block.settings.image
                        | image_url: width: block.settings.image.width
                        | image_tag: loading: 'lazy',
                          sizes: sizes,
                          widths: widths
                      }}
                    {%- endif -%}
                  </div>
                  <div class="testimonials__slide-wrapper">
                    {% if section.settings.quotes and block.settings.text != blank %}
                      <div class="testimonials__quotes">
                        {% render 'icon-quotes' %}
                      </div>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <div class="testimonials__slide-review richtext__content body-large">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                    {% if author_block or block.settings.product_id != blank %}
                      <div class="testimonials__slide-info{% if section.settings.rounded %} round_image{% endif %}">
                        {% if author_block %}
                          <div class="testimonials__slide-author">
                            {%- if block.settings.custom_icon != blank
                              or block.settings.custom_icon_dm != blank 
                              or block.settings.icon != 'none'
                            -%}
                              <div class="testimonials__slide-author-image">
                                  {%- assign widths = '360, 535, 720, 940, 1070' -%}
                                  {%- capture sizes -%}
                                    (min-width: 1100px) calc((100vw - 128px)), calc((100vw - 40px))
                                  {%- endcapture -%}
                                  {%- if block.settings.custom_icon != blank
                                    or block.settings.custom_icon_dm != blank
                                  -%}
                                    {% if block.settings.custom_icon != blank %}
                                      {%- assign height = 24
                                        | divided_by: block.settings.custom_icon.aspect_ratio
                                        | round: 2
                                      -%}
                                      {{
                                        block.settings.custom_icon
                                        | image_url: width: 96
                                        | image_tag:
                                          width: 24,
                                          height: height,
                                          widths: '24, 48, 72, 96',
                                          class: 'collapsible-content__icon custom_icon'
                                      }}
                                    {% endif %}
                                    {% if block.settings.custom_icon_dm != blank %}
                                      {%- assign dm_height = 24
                                        | divided_by: block.settings.custom_icon_dm.aspect_ratio
                                        | round: 2
                                      -%}
                                      {{
                                        block.settings.custom_icon_dm
                                        | image_url: width: 96
                                        | image_tag:
                                          width: 24,
                                          height: dm_height,
                                          widths: '24, 48, 72, 96',
                                          class: 'collapsible-content__icon custom_icon--dm'
                                      }}
                                    {% endif %}
                                  {%- elsif block.settings.icon != 'none' -%}
                                    {% render 'icon-pack',
                                      icon: block.settings.icon
                                    %}
                                  {%- endif -%}
                              </div>
                            {% endif %}
                            {% if block.settings.author_name != blank %}
                              <span class="testimonials__slide-author-name h4">
                                {{- block.settings.author_name | escape -}}
                              </span>
                            {% endif %}
                          </div>
                        {% endif %}
                        {% if block.settings.product_id != blank %}
                          {% render 'product-card-horizontal',
                            product_card_product: block.settings.product_id,
                            media_size: "1/1",
                            color_scheme: section.settings.color_scheme,
                            show_quickview: false,
                          %}
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                </div>
              {%- endfor -%}
            </div>
            {% if second_infinite %}
              <div class="testimonials__swiper-wrapper swiper-wrapper">
                {%- for block in section.blocks -%}
                  {% liquid 
                    assign author_block = false 
                    if block.settings.author_image != blank or block.settings.author_name != blank
                      assign author_block = true
                    endif
                  %}
                  <div
                    class="testimonials__slide focus-inset testimonials__slide--{{ slider_type }} swiper-slide color-{{ color_scheme }}{% if section.settings.notebook %} notebook-bg{% endif %}"
