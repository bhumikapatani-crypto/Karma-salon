                                          widths: '24, 48, 72, 96',
                                          class: 'collapsible-content__icon custom_icon'
                                      }}
                                    {% endif %}
                                    {% if block.settings.custom_icon_dm != blank %}
                                      {%- assign dm_height = 24
                                        | divided_by: block.settings.custom_icon_dm.aspect_ratio
                                        | round: 2
                                      -%}
                                      {{
                                        block.settings.custom_icon_dm
                                        | image_url: width: 96
                                        | image_tag:
                                          width: 24,
                                          height: dm_height,
                                          widths: '24, 48, 72, 96',
                                          class: 'collapsible-content__icon custom_icon--dm'
                                      }}
                                    {% endif %}
                                  {%- elsif block.settings.icon != 'none' -%}
                                    {% render 'icon-pack',
                                      icon: block.settings.icon
                                    %}
                                  {%- endif -%}
                                </div>
                              {% endif %}
                              {% if block.settings.author_name != blank %}
                                <span class="testimonials__slide-author-name h4">
                                  {{- block.settings.author_name | escape -}}
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                          {% if block.settings.product_id != blank %}
                            {% render 'product-card-horizontal',
                              product_card_product: block.settings.product_id,
                              media_size: "1/1",
                              color_scheme: section.settings.color_scheme,
                              show_quickview: false,
                            %}
                          {% endif %}
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {% endif %}
          </div>
        {% if slider_type == "infinite"  %}
          </div>
        {% endif %}

        {% if section.blocks.size > 1 and section.settings.show_arrows %}
          <div class="swiper-buttons">
            <div class="swiper-button swiper-button-prev">
              <div class="svg-embed">{% render 'icon-arrow' %}</div>
            </div>
            <div class="swiper-button swiper-button-next">
              <div class="svg-embed">{% render 'icon-arrow' %}</div>
            </div>
          </div>
        {% endif %}

        {%- if section.blocks.size > 1 -%}
          {% if section.settings.show_bullets %}
            <div class="testimonials__pagination swiper-pagination"></div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "section",
  "class": "testimonials-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.content_options.header.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-1",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "quotes",
      "label": "t:sections.testimonials.settings.quotes.label",
      "info": "t:sections.testimonials.settings.quotes.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "notebook",
      "label": "t:sections.all.notebook_bg.label",
      "info": "t:sections.testimonials.settings.notebook.info",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.compare-block.settings.product_options.label"
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "t:sections.testimonials.settings.rounded.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.slider_options.header.content"
    },
    {
      "type": "select",
      "id": "slider_type",
      "options": [
        {
          "value": "swiper",
          "label": "t:sections.testimonials.settings.slider_type.options__1.label"
        },
        {
          "value": "infinite",
          "label": "t:sections.testimonials.settings.slider_type.options__2.label"
        }
      ],
      "default": "swiper",
      "label": "t:sections.testimonials.settings.slider_type.label"
    },
    {
      "type": "checkbox",
      "id": "gradient",
      "label": "t:sections.testimonials.settings.gradient.label",
      "default": true,
      "info": "t:sections.testimonials.settings.gradient.info"
    },
    {
      "type": "checkbox",
      "id": "is_loop",
      "default": false,
      "label": "t:sections.all.slider_options.slider_is_loop.label",
      "info": "t:sections.testimonials.settings.loop.info"
    },
    {
      "type": "checkbox",
      "id": "is_autoplay",
      "default": false,
      "label": "t:sections.all.slider_options.slider_is_autoplay.label",
      "info": "t:sections.testimonials.settings.slider.autoplay.info"
    },
    {
      "type": "checkbox",
      "id": "is_hover_stop_autoplay",
      "default": true,
      "label": "t:sections.all.slider_options.slider_hover_autoplay_stop.label"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "t:sections.all.slider_options.navigation.label",
      "info": "t:sections.testimonials.settings.slider.swiper_only.info"
    },
    {
			"type": "checkbox",
			"id": "show_bullets",
			"default": true,
			"label": "t:sections.all.slider_options.pagination.label",
      "info": "t:sections.testimonials.settings.slider.swiper_only.info"
		},
    {
      "type": "range",
      "id": "slideshow_speed",
      "min": 0.1,
      "max": 10,
      "step": 0.1,
      "default": 1.1,
      "unit": "s",
      "label": "t:sections.all.slider_options.speed.label"
    },
    {
      "type": "range",
      "id": "slideshow_delay",
      "min": 0,
      "max": 8,
      "step": 0.1,
      "default": 4,
      "unit": "s",
      "label": "t:sections.all.slider_options.delay.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "t:sections.testimonials.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "default": "t:sections.testimonials.settings.description.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
  ],
  "blocks": [
    {
      "type": "testimonials_slide",
      "name": "t:sections.testimonials.blocks.testimonials_slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "inline_richtext",
          "id": "text",
          "default": "t:sections.testimonials.blocks.testimonials_slide.settings.review_text.default",
          "label": "t:sections.testimonials.blocks.testimonials_slide.settings.review_text.label"
        },
        {
          "type": "product",
          "id": "product_id",
          "label": "t:sections.product_markers.blocks.settings.product.label"
        },
        {
          "type": "header",
          "content": "t:sections.all.author.header.content"
        },
        {
          "type": "select",
          "id": "icon",
          "options": [
            {
              "value": "none",
              "label": "None"
            },
						{
							"value": "person",
							"label": "t:sections.all.icon_pack.options__34.label"
						},
						{
							"value": "person_2",
							"label": "t:sections.all.icon_pack.options__35.label"
						},
						{
							"value": "person_3",
							"label": "t:sections.all.icon_pack.options__36.label"
						},
						{
							"value": "person_4",
							"label": "t:sections.all.icon_pack.options__37.label"
						},
						{
							"value": "person_5",
							"label": "t:sections.all.icon_pack.options__38.label"
						},
						{
							"value": "person_6",
							"label": "t:sections.all.icon_pack.options__39.label"
