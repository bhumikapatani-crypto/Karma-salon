{{ 'section-image-slider.css' | asset_url | stylesheet_tag }}
<script
  src="{{ 'section-image-slider.js' | asset_url }}"
  defer="defer"
></script>

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

{% liquid
  assign slide_effects = section.settings.slide_effects
  assign image_slider_speed = section.settings.image_slider_speed
  assign autoplay = section.settings.is_autoplay
  assign loop = section.settings.is_loop
  assign stop_autoplay = section.settings.is_hover_stop_autoplay
  assign image_slider_delay = section.settings.image_slider_delay
  assign image_size = section.settings.image_size
  assign section_size = section.settings.section_size

  case image_size
    when 'adapt'
      assign section_height = 0
      assign slide_class = image_size
    when 'large'
      assign section_height = 'calc(100vh - var(--header-height) - var(--announcement-height))'
      assign slide_class = image_size
    else
      assign aspect_ratio = image_size | split: '/'
      assign temp = aspect_ratio[0] | append: '.0'
      assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
      assign slide_class = 'custom-ratio'
  endcase
%}
<div
  class="image-slider {{ slide_class }}"
  data-id="shopify-section-{{ section.id }}"
  data-autoplay="{{ autoplay }}"
  data-stop-autoplay="{{ stop_autoplay }}"
  data-speed="{{ image_slider_speed }}"
  data-delay="{{ image_slider_delay }}"
  data-effect="{{ slide_effects }}"
  data-loop="{{ loop }}"
  data-slide-count="{{ section.blocks.size }}"
  data-image_slider-size="{{ section_size }}"
>
  <div class="container">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}
  </div>
  <div class="image-slider__swiper swiper">
    <div class="image-slider__wrapper swiper-wrapper">
      {% for block in section.blocks %}
        {% liquid
          assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio
          assign adapt_height = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | append: '%'
          if image_size == 'adapt'
            if block.settings.image != blank
              assign section_height = adapt_height
            else
              assign section_height = '40%'
            endif
          endif
        %}
        <div
          class="image-slider-swiper__slide swiper-slide"
          {{ block.shopify_attributes }}
        >
          {% style %}
            [data-id="{{ block.id }}"].image-slider-slide {
              --slide-height: {{ section_height }};
            	--slide-overlay: rgba(var(--color-overlay), {{ block.settings.overlay_opacity }});

              {% if image_size != 'adapt' and image_size != 'large' %}
                --padding-bottom: {{ padding_bottom }}%;
              {% endif %}
            }
          {% endstyle %}
          <div
            class="image-slider-slide"
            data-id="{{ block.id }}"
          >
            <div class="image-slider-slide__container">
              {% if block.settings.image != blank and block.settings.video == blank %}
                <div class="image-slider-slide__img have-overlay">
                  {{
                    block.settings.image
                    | image_url: width: block.settings.image.width
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.image.width,
                      height: image_height,
                      sizes: '100vw',
                      widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                  }}
                </div>
              {% elsif block.settings.video != blank %}
                {{
                  block.settings.video
                  | video_tag:
                    loading: 'lazy',
                    sizes: '100vw',
                    class: 'data-alt',
                    widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
                    autoplay: true,
                    loop: true,
                    controls: false,
                    muted: true
                }}
              {% else %}
                <div class="image-slider-slide__img have-overlay">
                  {% assign placeholder_index = forloop.index | modulo: 3 | plus: 1 %}
                  {{ 'hero-apparel-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.blocks.size > 1 %}
      <div class="swiper-controls__wrapper no-js-hidden">
        <div class="container ">
          <div class="swiper-controls__box">
            {% if section.settings.show_arrows %}
              <div class="swiper-buttons__wrapper">
                <div class="swiper-buttons__box">
                  <div class="swiper-button swiper-button-prev">
                    <div class="svg-embed">{% render 'icon-arrow' %}</div>
                  </div>
                  <div class="swiper-button swiper-button-next">
                    <div class="svg-embed">{% render 'icon-arrow' %}</div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}
  </div>
  {% if section.settings.show_bullets and section.blocks.size > 1 %}
    <div class="swiper-pagination swiper-pagination-fraction"></div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:sections.image-slider.name",
  "tag": "section",
  "class": "image-slider-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "default": "t:sections.image-slider.settings.section_heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading.label__tag",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "default": "t:sections.image-slider.settings.section_description.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "section_button_label",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "section_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "select",
      "id": "image_size",
      "default": "21/9",
      "label": "t:sections.all.image.aspect_ratio.label",
      "info": "t:sections.all.image.aspect_ratio.info",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        },
        {
          "value": "adapt",
          "label": "t:sections.all.image.aspect_ratio.options__7.label"
        },
        {
          "value": "large",
          "label": "t:sections.all.image.aspect_ratio.options__8.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.slider_options.header.content"
    },
    {
      "type": "checkbox",
      "id": "is_loop",
      "default": true,
      "label": "t:sections.all.slider_options.slider_is_loop.label"
    },
    {
      "type": "checkbox",
      "id": "is_autoplay",
      "default": false,
      "label": "t:sections.all.slider_options.slider_is_autoplay.label"
    },
    {
      "type": "checkbox",
      "id": "is_hover_stop_autoplay",
      "default": true,
      "label": "t:sections.all.slider_options.slider_hover_autoplay_stop.label"
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "default": true,
      "label": "t:sections.all.slider_options.navigation.label"
    },
    {
      "type": "checkbox",
      "id": "show_bullets",
      "default": true,
      "label": "t:sections.all.slider_options.pagination.label"
    },
    {
      "type": "range",
      "id": "image_slider_speed",
      "min": 1,
      "max": 6,
      "step": 0.1,
      "default": 1.5,
      "unit": "s",
      "label": "t:sections.all.slider_options.speed.label"
    },
    {
      "type": "range",
      "id": "image_slider_delay",
      "min": 0,
      "max": 8,
      "step": 0.1,
      "default": 3,
      "unit": "s",
      "label": "t:sections.all.slider_options.delay.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-2",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "slide_effects",
      "options": [
        {
          "value": "slide",
          "label": "t:sections.all.slider_options.effects.options.options__1.label"
        },
        {
          "value": "fade",
          "label": "t:sections.all.slider_options.effects.options.options__2.label"
        },
        {
          "value": "coverflow",
          "label": "t:sections.all.slider_options.effects.options.options__3.label"
        },
        {
          "value": "creative",
          "label": "t:sections.all.slider_options.effects.options.options__4.label"
        }
      ],
      "default": "slide",
      "label": "t:sections.all.slider_options.effects.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "image_slider_item",
      "name": "t:sections.image-slider.blocks.name",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.all.video.label",
          "info": "t:sections.all.video.info"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 1,
          "step": 0.1,
          "default": 0,
          "label": "t:sections.all.overlay.overlay_opacity.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-slider.name",
      "blocks": [
        {
          "type": "image_slider_item"
        },
        {
          "type": "image_slider_item"
        },
        {
          "type": "image_slider_item"
        }
      ]
    }
  ]
}
{% endschema %}
