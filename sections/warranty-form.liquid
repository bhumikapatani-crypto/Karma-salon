{{ 'warranty-form.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

<div class="container">
  <div class="warranty-form">
    <h2 class="warranty-form__title">{{ section.settings.heading }}</h2>

    {%- form 'contact', id: 'WarrantyForm' -%}
      {%- if form.posted_successfully? -%}
        <div class="form-status" tabindex="-1" autofocus>
          {{ section.settings.success_message }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form-status form-status--error" tabindex="-1" autofocus>
          {% for field in form.errors %}
            {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
          {% endfor %}
        </div>
      {%- endif -%}

      <!-- Row 1: Name + Business -->
      <div class="warranty-form__row">
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-name">
            Name<span class="warranty-form__required">*</span>
          </label>
          <input
            class="warranty-form__input"
            type="text"
            id="WarrantyForm-name"
            name="contact[name]"
            placeholder="Enter your full name"
            required
            autocomplete="name"
            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
          >
        </div>
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-business">
            Business
          </label>
          <input
            class="warranty-form__input"
            type="text"
            id="WarrantyForm-business"
            name="contact[business]"
            placeholder="Business name (if applicable)"
            autocomplete="organization"
          >
        </div>
      </div>

      <!-- Row 2: Phone + Email -->
      <div class="warranty-form__row">
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-phone">
            Phone Number<span class="warranty-form__required">*</span>
          </label>
          <div class="warranty-form__phone-group">
            <select class="warranty-form__phone-country" id="WarrantyForm-country" name="contact[country_code]" aria-label="Country code">
              <option value="+61">🇦🇺 +61</option>
              <option value="+1">🇺🇸 +1</option>
              <option value="+44">🇬🇧 +44</option>
              <option value="+91">🇮🇳 +91</option>
              <option value="+64">🇳🇿 +64</option>
              <option value="+86">🇨🇳 +86</option>
              <option value="+81">🇯🇵 +81</option>
              <option value="+49">🇩🇪 +49</option>
              <option value="+33">🇫🇷 +33</option>
            </select>
            <input
              class="warranty-form__phone-input"
              type="tel"
              id="WarrantyForm-phone"
              name="contact[phone]"
              placeholder="+61 412 345 678"
              required
              autocomplete="tel"
            >
          </div>
        </div>
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-email">
            Email<span class="warranty-form__required">*</span>
          </label>
          <input
            class="warranty-form__input"
            type="email"
            id="WarrantyForm-email"
            name="contact[email]"
            placeholder="Enter your email address"
            required
            autocomplete="email"
            autocapitalize="off"
            spellcheck="false"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
            {% endif %}
          >
        </div>
      </div>

      <!-- Row 3: Invoice Number + Purchase Date -->
      <div class="warranty-form__row">
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-invoice">
            Invoice Number<span class="warranty-form__required">*</span>
          </label>
          <input
            class="warranty-form__input"
            type="text"
            id="WarrantyForm-invoice"
            name="contact[invoice_number]"
            placeholder="Enter the invoice number"
            required
          >
        </div>
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-date">
            Purchase Date<span class="warranty-form__required">*</span>
          </label>
          <input
            class="warranty-form__input"
            type="date"
            id="WarrantyForm-date"
            name="contact[purchase_date]"
            required
          >
        </div>
      </div>

      <!-- Row 4: Product Title -->
      <div class="warranty-form__row warranty-form__row--single">
        <div class="warranty-form__field">
          <label class="warranty-form__label" for="WarrantyForm-product">
            Product Title
          </label>
          <input
            class="warranty-form__input"
            type="text"
            id="WarrantyForm-product"
            name="contact[product_title]"
            placeholder="Product Title"
          >
        </div>
      </div>

      <!-- Row 5: Issue Description — mapped to body so Shopify includes it as the main message -->
      <div class="warranty-form__field warranty-form__field--textarea">
        <label class="warranty-form__label" for="WarrantyForm-issue">
          Issue Description<span class="warranty-form__required">*</span>
        </label>
        <textarea
          class="warranty-form__textarea"
          id="WarrantyForm-issue"
          name="contact[body]"
          placeholder="Describe the issue in detail"
          required
        >{{ form.body }}</textarea>
      </div>

      <!-- Row 6: Photo Upload (visual only — Shopify contact forms cannot send file attachments) -->
      <div class="warranty-form__field">
        <label class="warranty-form__label">
          Add Photos<span class="warranty-form__required">*</span>
        </label>
        <div class="warranty-form__upload-area" id="warranty-upload-area">
          <input
            class="warranty-form__upload-input"
            type="file"
            id="WarrantyForm-photos"
            accept="image/*"
            multiple
          >
          <div>
            <button type="button" class="warranty-form__upload-btn" onclick="document.getElementById('WarrantyForm-photos').click();">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Upload
            </button>
            <span class="warranty-form__upload-text">Drag and drop or browse files</span>
            <span class="warranty-form__upload-hint">Files Supported: Image</span>
            <span class="warranty-form__upload-hint">Maximum 3 files</span>
          </div>
          <div class="warranty-form__upload-preview" id="warranty-upload-preview"></div>
        </div>
      </div>

      <!-- Hidden field to identify this as warranty form -->
      <input type="hidden" name="contact[form_type]" value="Warranty Submission">

      <!-- Submit -->
      <button type="submit" class="warranty-form__submit">
        Submit
      </button>
    {%- endform -%}
  </div>
</div>

<script>
  (function() {
    var fileInput = document.getElementById('WarrantyForm-photos');
    var previewContainer = document.getElementById('warranty-upload-preview');
    if (!fileInput || !previewContainer) return;

    fileInput.addEventListener('change', function() {
      previewContainer.innerHTML = '';
      var files = Array.from(this.files).slice(0, 3);
      files.forEach(function(file) {
        if (!file.type.startsWith('image/')) return;
        var reader = new FileReader();
        reader.onload = function(e) {
          var item = document.createElement('div');
          item.className = 'warranty-form__upload-preview-item';
          var img = document.createElement('img');
          img.src = e.target.result;
          img.alt = file.name;
          item.appendChild(img);
          previewContainer.appendChild(item);
        };
        reader.readAsDataURL(file);
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Warranty Form",
  "tag": "section",
  "class": "spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "WARRANTY SUBMISSION FORM",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "success_message",
      "default": "Thank you for your warranty submission. We will review your claim and get back to you shortly.",
      "label": "Success message"
    },
    {
      "type": "header",
      "content": "Section margin"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" }
      ],
      "default": "m",
      "label": "Margin top"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        { "value": "no-indent", "label": "None" },
        { "value": "s", "label": "Small" },
        { "value": "m", "label": "Medium" },
        { "value": "l", "label": "Large" }
      ],
      "default": "m",
      "label": "Margin bottom"
    }
  ],
  "presets": [
    {
      "name": "Warranty Form"
    }
  ]
}
{% endschema %}
