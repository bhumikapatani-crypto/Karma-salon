{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'section-featured-blog.css' | asset_url | stylesheet_tag }}
<script src="{{ 'featured-blog.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{% liquid
  assign post_limit = section.settings.post_limit
  assign column_per_row = section.settings.columns_per_row
  assign image_ratio = section.settings.image_ratio
  assign columns_mobile = section.settings.columns_mobile
  assign enable_swiper = section.settings.enable_swiper
  assign layout = section.settings.content_layout
  assign layout_4 = false
  if layout contains "layout4" 
    assign layout_4 = true
  endif

  assign show_tags = section.settings.show_tags
  assign show_date = section.settings.show_date
  assign show_author = section.settings.show_author
  assign show_excerpt = section.settings.show_excerpt
%}

{% assign four_col_two = false %}

<div class="blog">
  <div class="container">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}

    {% assign is_spec_case = false %}

    <div class="blog__posts__container">
      <div
        class="blog__posts{% if enable_swiper and post_limit > 1 and layout_4 == false %} swiper swiper--articles{% endif %}{% if layout_4 %} no-swiper{% endif %}"
        data-columns-mobile="{{columns_mobile}}" data-columns="{{ column_per_row }}"
      >
        <div class="blog__posts-wrapper 
            blog__posts-wrapper--count-{{ post_limit }}
           blog__posts-wrapper--{% if layout_4 %}layout4{% else %}{{ column_per_row }}{% endif %}
         blog__posts-wrapper--{{columns_mobile}}-mobile {% if enable_swiper and post_limit > 1 and layout_4 == false %} swiper-wrapper{% endif %}">
          {%- if section.settings.blog != blank
            and section.settings.blog.articles_count > 0
          -%}
            {%- for article in section.settings.blog.articles
              limit: post_limit
          -%}
            {% if layout_4 %}
              {% if forloop.first %}
                <div class="article-card__layout-4--first-col color-background-2">
              {% endif %}
            {% endif %}

            {% if layout_4 and forloop.first == false and forloop.index == 2 %}
              {% assign four_col_two = true %}
            {% endif %}
          
            {% if four_col_two  %}
              <div class="article-card__layout-4--col-2">
            {% endif %}
          
            <div
              class="blog__post article {% if four_col_two  %} blog__post--second-child{% endif %}{% if enable_swiper and post_limit > 1 and layout_4 == false %} swiper-slide{% endif %}
              {% if settings.animations_reveal_on_scroll %} scroll-trigger
              {% if four_col_two %} animate--bounce-left{% else %} animate--slide-in{% endif %}
              {% endif %}"
          {% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}
              data-id="{{ article.id }}"
            >
              {% style %}
                #shopify-section-{{ section.id }} [data-id="{{ article.id }}"].blog__post {
                  {% if image_ratio != 'adapt' %}
                    --aspect-ratio: {{ image_ratio }};
                  {% elsif image_ratio == 'adapt' and article.image != blank %}
                    --aspect-ratio: {{ article.image.width }}/{{ article.image.height }};
                  {% endif %}
                }
              {% endstyle %}
              
              {% render 'article-card',
                blog: section.settings.blog,
                article: article,
                layout: layout,
                show_image: section.settings.show_image,
                show_tags: section.settings.show_tags,
                show_date: section.settings.show_date,
                show_author: section.settings.show_author,
                show_excerpt: section.settings.show_excerpt,
                layout_4: layout_4,
                first: forloop.first
              %}
            </div>
          
            {% if layout_4 %}
              {% if forloop.first %}
                </div>
              {% elsif forloop.last %}
                </div>
              {% endif %}
            {% endif %}
          {%- endfor -%}
          
          {%- else -%}
            {% style %}
              #shopify-section-{{ section.id }} .blog__post {
                --aspect-ratio: {{ image_ratio }};
                {% if image_ratio == 'adapt' %}
                  --aspect-ratio: 16/9;
                {% endif %}
              }
            {% endstyle %}
            {% for i in (1..post_limit) %}
              {% if layout_4 %}
                {% if forloop.first %}
                  <div class="article-card__layout-4--first-col color-background-2">
                {% endif %}
              {% endif %}

              {% if layout_4 and forloop.first == false and forloop.index == 2 %}
                {% assign four_col_two = true %}
              {% endif %}
            
              {% if four_col_two  %}
                <div class="article-card__layout-4--col-2">
              {% endif %}
            
                <div
                  class="blog__post article {% if four_col_two  %} blog__post--second-child{% endif %}{% if enable_swiper and post_limit > 1 and layout_4 == false %} swiper-slide{% endif %}
                  {% if settings.animations_reveal_on_scroll %} scroll-trigger
                  {% if four_col_two %} animate--bounce-left{% else %} animate--slide-in{% endif %}
                  {% endif %}"
                  {% if settings.animations_reveal_on_scroll %} data-cascade{% endif %}
                  data-id="{{ article.id }}"
                >
                  <article class="article-card{% if layout %} article-card--{{ layout }}{% endif %}">
                    {% if layout_4 %}
                      <div class="article-card__overlay-4" style="opacity: {{ section.settings.overlay_opacity }}"></div>
                    {% endif %}
                    <div class="article-card__image-wrapper{% if section.settings.show_image %} has-ratio{% endif %}">
                      {% if section.settings.show_image == true %}
                        <div class="article-card__image">
                          {% assign placeholder_index = forloop.index | modulo: 3 | plus: 1 %}
                          {{
                            'blog-apparel-'
                            | append: placeholder_index
                            | placeholder_svg_tag: 'placeholder-svg'
                          }}
                        </div>
                      {% endif %}
                      {% if layout == "layout1" %}
                        {%- if show_tags -%}
                          <div class="article-card__tags article-card__block-on-image{% if blog.url == blank %} no-events{% endif %}">
                              <div class="article-card__tag subheading">
                                <span title="{{ 'sections.featured_blog.tag' | t }}">
                                  {{ 'sections.featured_blog.tag' | t }}
                                </span>
                              </div>
                          </div>
                        {%- endif -%}
                      {% elsif layout == "layout2" %}
                        {%- if show_date -%}
                          <span class="article-card__date layout2 secondary_text article-card__block-on-image{% if blog.url == blank %} no-events{% endif %}">
                            {{ 'sections.featured_blog.date' | t }}
                          </span>
                        {%- endif -%}
                      {% endif %}
                    </div>
                    <header class="article-card__header">
                      {% if layout_4 and forloop.first %}
                        <a
                          class="article-card-link"
                          href="{{ article.url }}"
                          aria-label="{{ 'accessibility.article_link' | t }}"
                        ></a>
                      {% endif %}
                      <div class="article-card__content-wrapper">
                        {% if layout == "layout1" %}<div class="article-card__title-wrapper-layout1">{% endif %}
                          <h4 class="article-card__title {% if layout_4 and forloop.first %}h1{% else %}h3{% endif %}">
                            {{ 'sections.featured_blog.onboarding_title' | t }}
                          </h4>
                          {% if layout == "layout1" %}
                            {%- if show_date or show_tags or show_author -%}
                              <div class="article-card__meta article-card__meta--author-tags">
                                {%- if show_date or show_author -%}
                                  <div class="article-card__info">
                                    {%- if show_author -%}
                                      <div class="article-card__author secondary_text">
                                        <span>
                                          {{ 'sections.featured_blog.author' | t }}
                                        </span>
                                      </div>
                                    {%- endif -%}
                                    {% if layout != "layout2" %}
                                      {%- if show_date -%}
                                        <span class="article-card__date secondary_text{% if blog.url == blank %} no-events{% endif %}">
                                          {{ 'sections.featured_blog.date' | t }}
                                        </span>
                                      {%- endif -%}
                                    {% endif %}
                                  </div>
                                {%- endif -%}
                              </div>
                            {%- endif -%}
                          {% endif %}
                        {% if layout == "layout1" %}</div>{% endif %}
                        {% if show_excerpt %}
                          <p class="article-card__excerpt  {% if template == 'search' %} article-card__excerpt_small {% endif %}">
                            {{ 'sections.featured_blog.onboarding_content' | t }}
                          </p>
                        {% endif %}
                      </div>
                      
                      {% if layout != "layout1" %}
                        {%- if show_date or show_tags or show_author -%}
                          <div class="article-card__meta article-card__meta--author-tags">
                            {% if layout == blank %}
                              {%- if show_tags -%}
                                <div class="article-card__tags{% if blog.url == blank %} no-events{% endif %} {% if layout_4 and forloop.first %}color-background-1{% endif %}">
                                    <div class="article-card__tag subheading">
                                        <span title="{{ 'sections.featured_blog.tag' | t }}">
                                          {{ 'sections.featured_blog.tag' | t }}
                                        </span>
                                    </div>
                                </div>
                              {%- endif -%}
                            {% endif %}
                            {%- if show_date or show_author -%}
                              <div class="article-card__info">
                                {%- if show_author -%}
                                  <div class="article-card__author secondary_text">
                                    <span>
                                      {{ 'sections.featured_blog.author' | t }}
                                    </span>
                                  </div>
                                {%- endif -%}
                                {% if layout != "layout2" %}
                                  {%- if show_date -%}
                                    <span class="article-card__date secondary_text{% if blog.url == blank %} no-events{% endif %}">
                                      {{ 'sections.featured_blog.date' | t }}
                                    </span>
                                  {%- endif -%}
                                {% endif %}
                              </div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {% endif %}

                    </header>
                  </article>
                </div>
                {% if layout_4 %}
                {% if forloop.first %}
                  </div>
                {% elsif forloop.last %}
                  </div>
                {% endif %}
              {% endif %}
            {% endfor %}
          {% endif %}
      </div>
    </div>
    {%- if enable_swiper and post_limit > 1 and layout_4 == false -%}
      {% if section.settings.show_arrows %}
        <div class="blog__button-prev swiper-button swiper-button-prev color-{{ settings.color_scheme }}">
          <div class="svg-embed">{% render 'icon-arrow' %}</div>
        </div>
        <div class="blog__button-next swiper-button swiper-button-next color-{{ settings.color_scheme }}">
          <div class="svg-embed">{% render 'icon-arrow' %}</div>
        </div>
      {% endif %}
      {% if section.settings.show_bullets %}
        <div class="blog__pagination swiper-pagination"></div>
      {% endif %}
    {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.featured-blog.name",
  "tag": "section",
  "class": "spaced-section section-featured-blog",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "t:sections.featured-blog.settings.blog.label"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "t:sections.featured-blog.settings.post_limit.label"
    },
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "t:sections.all.columns.label",
      "info": "t:sections.all.columns.info_2"
    },
    {
      "type": "select",
      "id": "content_layout",
      "label": "t:sections.featured-blog.settings.content_layout.label",
      "default": "layout4",
      "options": [
        { "value": "layout1", "label": "t:sections.featured-blog.settings.content_layout.options__1.label" },
        { "value": "layout2", "label": "t:sections.featured-blog.settings.content_layout.options__2.label" },
        { "value": "layout3", "label": "t:sections.featured-blog.settings.content_layout.options__3.label" },
        { "value": "layout4", "label": "t:sections.featured-blog.settings.content_layout.options__4.label" }
      ]
    },
		{
			"type": "range",
			"id": "overlay_opacity",
			"step": 0.1,
			"default": 0.2,
			"min": 0,
			"max": 1,
			"info": "t:sections.featured-blog.settings.overlay_opacity.info",
			"label": "t:sections.all.overlay.overlay_opacity.label_secondary"
		},
    {
      "type": "checkbox",
      "id": "show_image",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_tags",
      "default": true,
      "label": "t:sections.main-blog.settings.show_tags.label"
    },
    {
      "type": "checkbox",
      "id": "show_date",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_date.label"
    },
    {
      "type": "checkbox",
      "id": "show_author",
      "default": false,
      "label": "t:sections.featured-blog.settings.show_author.label"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "default": true,
      "label": "t:sections.featured-blog.settings.show_excerpt.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
			"type": "header",
			"content": "t:sections.all.slider_options.header.content"
		},
    {
      "type": "checkbox",
      "id": "enable_swiper",
      "label": "t:sections.all.slider.enable_slider.label",
      "default": false,
      "info": "t:sections.featured-blog.settings.enable_swiper.info"
    },
		{
			"type": "checkbox",
			"id": "show_arrows",
			"default": true,
			"label": "t:sections.all.slider_options.navigation.label"
		},
		{
			"type": "checkbox",
			"id": "show_bullets",
			"default": true,
			"label": "t:sections.all.slider_options.pagination.label"
		},
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "16/9",
      "label": "t:sections.all.image.aspect_ratio.label",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "default": "t:sections.featured-blog.settings.section_heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "text",
      "id": "section_description",
      "label": "t:sections.all.text.label",
      "default": "t:sections.featured-blog.settings.section_description.default"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "section_button_label",
      "default": "t:sections.all.button.button_label.default_4",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "section_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "tertiary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
  ],
  "presets": [
    {
      "name": "t:sections.featured-blog.presets.name"
    }
  ]
}
{% endschema %}
