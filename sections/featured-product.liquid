                                    {{ 'products.product.add_to_cart' | t }}
                                  </span>
                                  <div class="button-circle">
                                    <div class="svg-embed">
                                      {% render 'icon-small-arrow' %}
                                    </div>
                                  </div>
                                  <div class="loading-overlay__spinner hidden">
                                    {%- render 'icon-spinner' -%}  
                                  </div>
                                {%- else -%}
