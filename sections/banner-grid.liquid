{{ 'section-banner-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'banner-grid.js' | asset_url }}" defer="defer"></script>

{% style %}
  {% render 'section-margin' %}
{% endstyle %}

{% assign is_animated = section.settings.is_animated_heading %}

<div class="banner-grid" data-animation="{{ is_animated }}">
  <div class="container">
    {% render 'section-header',
      section_heading: section.settings.section_heading,
      heading_tag: section.settings.heading_tag,
      section_description: section.settings.section_description,
      button_label: section.settings.section_button_label,
      button_link: section.settings.section_button_link,
      button_style: section.settings.section_button_style
    %}
    <div class="banner-grid__wrapper promo-position-{{ section.settings.image_position }} card-{{ section.settings.columns_per_row }}">
      {% style %}
        #shopify-section-{{ section.id }} .banner-grid__wrapper {
        	--opacity-overlay: {{ section.settings.overlay_opacity }};
        	--aspect-ratio: {{ section.settings.image_ratio }};
        }
      {% endstyle %}
      <div class="banner-grid__promo {% if section.settings.image_parallax %}jarallax{% endif %} color-{{ section.settings.color_scheme }}">
        <span class="banner-grid__promo-img__overlay"></span>
        <div class="banner-grid__promo-img {% if section.settings.image_parallax %}jarallax-img{% endif %}">
          {% if section.settings.image != blank and section.settings.video == blank %}
            {{
              section.settings.image
              | image_url: width: section.settings.image.width
              | image_tag: loading: 'lazy', widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200'
            }}
          {% elsif section.settings.video != blank %}
            {{
              section.settings.video
              | video_tag:
                loading: 'lazy',
                class: 'data-alt',
                widths: '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200',
                autoplay: true,
                loop: true,
                controls: false,
                muted: true
            }}
          {% else %}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        <div class="banner-grid__promo-content {% if section.settings.text != blank %} text-{{ section.settings.text_position }} {% endif %}">
          {%- if section.settings.heading != blank -%}
            <{{ section.settings.heading_tag }}
              class="banner-grid__promo-content__heading h0 {{ section.settings.heading_max_width }} {% if is_animated %} animated-heading{% endif %}"
              data-speed="{{ section.settings.heading_animation_speed }}"
              data-animated_text="{{ section.settings.heading }}"
            >
              <span
                class="banner-grid__promo-content__heading--inner{% if is_animated %} animated-heading--inner{% endif %}"
                {% if is_animated %}
                  style="opacity: 0;"
                {% endif %}
              >
                {{- section.settings.heading -}}
              </span>
            </{{ section.settings.heading_tag }}>
          {%- endif -%}
          {%- if section.settings.text != blank -%}
            <div
              class="banner-grid__promo-content__text {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
              {% endif %}
            >
              {{ section.settings.text }}
            </div>
          {%- endif -%}
        </div>
      </div>
      {%- for block in section.blocks -%}
        <div class="banner-grid__card">
          <div class="banner-grid__card-img">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: block.settings.image.width
                | image_tag: loading: 'lazy', widths: '360, 535, 720, 940'
              }}
            {% else %}
              {% assign product_index = forloop.index | modulo: 4 | plus: 1 %}
              {{ 'product-apparel-' | append: product_index | placeholder_svg_tag: 'placeholder' }}
            {% endif %}
          </div>

          {% if block.settings.button_label != blank %}
            <a
              {% if block.settings.button_link != blank %}
                href="{{ block.settings.button_link }}"
                data-button-text="{{ block.settings.button_label | escape }}"
              {% endif %}
              class="button--link banner-grid__card-link h4"
              {% if block.settings.button_link == blank %}
                aria-disabled="true"
              {% endif %}
              aria-label="{{ block.settings.button_label | escape }}"
            >
              <span>
                {{ block.settings.button_label }}
              </span>

              {% render 'icon-small-arrow' %}
            </a>
          {% endif %}
          {% if block.settings.button_link != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="overlay_link"
              aria-label="{{ block.settings.button_label | escape }}"
            >
            </a>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.banner-grid.name",
  "tag": "section",
  "class": "banner-grid-section spaced-section",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "range",
      "id": "columns_per_row",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 2,
      "label": "t:sections.all.columns.label",
      "info": "t:sections.all.columns.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.image.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "1/1",
      "label": "t:sections.all.image.aspect_ratio.label",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        },
        {
          "value": "4/3",
          "label": "t:sections.all.image.aspect_ratio.options__4.label"
        },
        {
          "value": "16/9",
          "label": "t:sections.all.image.aspect_ratio.options__5.label"
        },
        {
          "value": "21/9",
          "label": "t:sections.all.image.aspect_ratio.options__6.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.header.content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "default": "t:sections.featured-collection.settings.collection_card.section_heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "section_heading_size",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "default": "t:sections.featured-collection.settings.collection_card.section_description.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.button.header_button.content"
    },
    {
      "type": "text",
      "id": "section_button_label",
      "default": "t:sections.all.button.button_label.default_1",
      "label": "t:sections.all.button.button_label.label",
      "info": "t:sections.all.button.button_label.info"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "t:sections.all.button.button_link.label"
    },
    {
      "type": "select",
      "id": "section_button_style",
      "options": [
        {
          "value": "primary",
          "label": "t:sections.all.button.button_style.options__1.label"
        },
        {
          "value": "secondary",
          "label": "t:sections.all.button.button_style.options__2.label"
        },
        {
          "value": "tertiary",
          "label": "t:sections.all.button.button_style.options__3.label"
        }
      ],
      "default": "secondary",
      "label": "t:sections.all.button.button_style.label"
    },
    {
      "type": "header",
      "content": "t:sections.banner-grid.settings.promo_banner.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.all.image.label"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.all.video.label",
      "info": "t:sections.all.video.info"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.1,
      "label": "t:sections.all.overlay.overlay_opacity.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "background-2",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "image_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.banner-grid.settings.promo_banner.image_position.options__1.label"
        },
        {
          "value": "right",
          "label": "t:sections.banner-grid.settings.promo_banner.image_position.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:sections.banner-grid.settings.promo_banner.image_position.label"
    },
    {
      "type": "checkbox",
      "id": "image_parallax",
      "default": true,
      "label": "t:sections.featured-collection.settings.collection_card.image_parallax"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "t:sections.banner-grid.settings.heading.default",
      "label": "t:sections.all.heading.label"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_tag.options__1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_tag.options__2.label"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_tag.options__3.label"
        },
        {
          "value": "h4",
          "label": "t:sections.all.heading_tag.options__4.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_tag.options__5.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_tag.options__6.label"
        },
        {
          "value": "div",
          "label": "t:sections.all.heading_tag.options__7.label"
        },
        {
          "value": "p",
          "label": "t:sections.all.heading_tag.options__8.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading.label__tag",
      "info": "t:sections.all.heading_tag.info"
    },
    {
      "type": "select",
      "id": "heading_max_width",
      "options": [
        {
          "value": "medium",
          "label": "t:sections.all.heading_max_width.option__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.all.heading_max_width.option__2.label"
        }
      ],
      "default": "medium",
      "label": "t:sections.all.heading_max_width.label"
    },
    {
      "type": "textarea",
      "id": "text",
      "default": "t:sections.banner-grid.settings.text.default",
      "label": "t:sections.all.text.label"
    },
    {
      "type": "select",
      "id": "text_position",
      "options": [
        {
          "value": "center",
          "label": "t:sections.all.text_position.options__1.label"
        },
        {
          "value": "bottom",
          "label": "t:sections.all.text_position.options__2.label"
        }
      ],
      "default": "bottom",
      "label": "t:sections.all.text_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-banner.settings.heading_animation.label"
    },
    {
      "type": "checkbox",
      "id": "is_animated_heading",
      "default": true,
      "label": "t:sections.image-banner.settings.enable_heading_animation.label"
    },
    {
      "type": "range",
      "id": "heading_animation_speed",
      "min": 50,
      "max": 300,
      "step": 50,
      "label": "t:sections.image-banner.settings.heading_animation_speed.label",
      "default": 150
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
      "type": "select",
      "id": "margin_top",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "no-indent",
      "label": "t:sections.all.section-margin.margin_top.label"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "options": [
        {
          "value": "no-indent",
          "label": "t:sections.all.section-margin.options__1.label"
        },
        {
          "value": "s",
          "label": "t:sections.all.section-margin.options__3.label"
        },
        {
          "value": "m",
          "label": "t:sections.all.section-margin.options__4.label"
        },
        {
          "value": "l",
          "label": "t:sections.all.section-margin.options__5.label"
        }
      ],
      "default": "m",
      "label": "t:sections.all.section-margin.margin_bottom.label"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.banner-grid.blocks.card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.all.image.label"
        },
        {
          "type": "header",
          "content": "t:sections.all.button.header_button.content"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "t:sections.banner-grid.settings.button_label.default",
          "label": "t:sections.all.button.button_label.label",
          "info": "t:sections.all.button.button_label.info"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.all.button.button_link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.banner-grid.presets.name",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
