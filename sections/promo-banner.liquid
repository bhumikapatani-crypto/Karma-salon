{{ 'section-promo-banner.css' | asset_url | stylesheet_tag }}

<script src="{{ 'promo-banner.js' | asset_url }}" defer="defer"></script>

{% liquid
	assign image_ratio = section.settings.image_ratio
	assign is_animated = section.settings.is_animated_heading

	if image_ratio == 'adapt'
		if section.settings.image == blank
			assign aspect_ratio = 0
			assign padding_bottom = '35vw'
		else
			assign aspect_ratio = section.settings.image.aspect_ratio
			assign padding_bottom = 'calc((100vw - var(--scrollbar-width, "0px")) / (var(--aspect_ratio)))'
		endif
	elsif image_ratio == 'large'
		assign padding_bottom = 'calc(100vh - var(--header-height, "0px"))'
	else
		assign aspect_ratio = image_ratio
		assign padding_bottom = 'calc((100vw - var(--scrollbar-width, "0px")) / (var(--aspect_ratio)))'
	endif

	assign is_second_media = false
	if section.settings.image_2 != blank or section.settings.video_2 != blank
		assign is_second_media = true
	endif
%}

{% style %}
	{% render 'section-margin' %}

	#shopify-section-{{ section.id }} .promo-banner {
	  --aspect_ratio: {{ aspect_ratio }};
	}

	#shopify-section-{{ section.id }} .promo-banner__overlay {
	  opacity: {{ section.settings.overlay_opacity }};
	}

	@media screen and (max-width: 989px) {
	  #shopify-section-{{ section.id }} .promo-banner__container .promo-banner__media {
	    min-height: calc(100vw - var(--scrollbar-width));
	  }
	}

	@media screen and (min-width: 990px) {
	  #shopify-section-{{ section.id }} .promo-banner__container {
	    min-height: {{ padding_bottom }};
	  }
	}
{% endstyle %}

<div
	class="promo-banner color-{{ section.settings.color_scheme }} overlay"
	data-animation="{{ is_animated }}"
>
	<div class="promo-banner__container{% if is_second_media %} promo-banner__container--2{% endif %}">
		{% liquid
			assign width_adapt_ratio = 1
			if section.settings.image.width > section.settings.image.height
				assign width_adapt_ratio = 550 | times: section.settings.image.aspect_ratio | round: 2
			endif

			assign desktop_width = 'calc(100vw - 64px * 2)'
		%}
		{% capture sizes %}
        (min-width: 1100px) {{ desktop_width }}, 
        {% if width_adapt_ratio != 1 %}
          {{ width_adapt_ratio }}px
        {% else %}
          100vw
        {% endif %}
      {% endcapture %}
		{% liquid
			assign image_loading = 'lazy'
			assign fetch_priority = 'auto'
			if section.index == 1
				assign image_loading = 'eager'
				assign fetch_priority = 'high'
			endif
		%}
		<div class="promo-banner__media">
			<span class="promo-banner__overlay"></span>
			{% if section.settings.button_link != blank
				and section.settings.overlay_link
			%}
				<a
					href="{{ section.settings.button_link }}"
					class="promo-banner__overlay--link"
				></a>
			{% endif %}
			{% if section.settings.subheading != blank
				or section.settings.heading_2 != blank
				or section.settings.description != blank
				or section.settings.button_label != blank
			%}
				<div class="promo-banner__wrapper">
					<div class="promo-banner__content-wrapper promo-banner__content-wrapper--content-left">
						<div class="promo-banner__content {% if section.settings.percent == blank %} promo-banner__content--only-content{% endif %}">
							{%- if section.settings.subheading != blank -%}
								<div
									class="promo-banner__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
									{% if settings.animations_reveal_on_scroll %}
										data-cascade
									{% endif %}
								>
									{{ section.settings.subheading }}
								</div>
							{%- endif -%}
						</div>
						<div class="promo-banner__promo">
							{% if section.settings.heading_2 != blank %}
								<h2
									class="promo-banner__promo--heading h0{% if is_animated %} animated-heading{% elsif settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
									data-speed="{{ section.settings.heading_animation_speed }}"
									{% if settings.animations_reveal_on_scroll
										and is_animated == false
									%}
										data-cascade
									{% endif %}
									data-animated_text="{{ section.settings.heading_2 }}"
								>
									<span
										class="promo-banner__promo--heading--inner{% if is_animated %} animated-heading--inner{% endif %}"
										{% if is_animated %}
											style="opacity: 0;"
										{% endif %}
									>
										{{- section.settings.heading_2 -}}
									</span>
								</h2>
							{% endif %}
							{% if section.settings.description != blank %}
								<div
									class="promo-banner__promo--description{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in-text{% endif %}"
									{% if settings.animations_reveal_on_scroll %}
										data-cascade
									{% endif %}
								>
									{{ section.settings.description }}
								</div>
							{% endif %}
						</div>
					</div>
					{% if section.settings.button_label != blank %}
						{% assign button_label = section.settings.button_label %}
						{% assign btn_classes = 'promo-banner__button focus-inset' %}
						{% if settings.animations_reveal_on_scroll %}
							{% assign btn_classes = btn_classes
								| append: ' scroll-trigger animate--slide-in-text'
							%}
						{% endif %}

						{% render 'button',
							btn_label: button_label,
							btn_link: section.settings.button_link,
							btn_style: section.settings.button_style,
							add_classes: btn_classes,
							data-cascade: true
						%}
					{% endif %}
				</div>
			{% endif %}
			{%- if section.settings.image != blank
				and section.settings.video == blank
			-%}
				{{
					section.settings.image
					| image_url: width: section.settings.image.width
					| image_tag:
						loading: image_loading,
						fetchpriority: fetch_priority,
						sizes: sizes,
						widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
				}}
			{%- elsif section.settings.video != blank -%}
				{{
					section.settings.video
					| video_tag:
						image_size: '1920x',
						autoplay: true,
						loop: true,
						controls: false,
						muted: true,
						class: 'data-alt'
				}}
			{%- else %}
				{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
			{%- endif -%}
		</div>
		{% if is_second_media %}
			<div class="promo-banner__media">
				<span class="promo-banner__overlay"></span>
				{%- if section.settings.image_2 != blank
					and section.settings.video_2 == blank
				-%}
					{{
						section.settings.image_2
						| image_url: width: section.settings.image_2.width
						| image_tag:
							loading: image_loading,
							fetchpriority: fetch_priority,
							sizes: sizes,
							widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
					}}
				{%- elsif section.settings.video_2 != blank -%}
					{{
						section.settings.video_2
						| video_tag:
							image_size: '1920x',
							autoplay: true,
							loop: true,
							controls: false,
							muted: true,
							class: 'data-alt'
					}}
				{%- endif -%}
			</div>
		{% endif %}
	</div>
</div>

{% schema %}
{
	"name": "t:sections.promo-banner.name",
	"tag": "section",
	"class": "promo-banner-section spaced-section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-2",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.image.header.content__1"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.all.image.label"
		},
		{
			"type": "video",
			"id": "video",
			"label": "t:sections.all.video.label",
			"info": "t:sections.all.video.info"
		},
		{
			"type": "image_picker",
			"id": "image_2",
			"label": "t:sections.all.image.label_secondary"
		},
		{
			"type": "video",
			"id": "video_2",
			"label": "t:sections.all.video.label_2",
			"info": "t:sections.all.video.info"
		},
		{
			"type": "select",
			"id": "image_ratio",
			"default": "large",
			"label": "t:sections.all.image.aspect_ratio.label",
			"options": [
				{
					"value": "1/1",
					"label": "t:sections.all.image.aspect_ratio.options__1.label"
				},
				{
					"value": "3/2",
					"label": "t:sections.all.image.aspect_ratio.options__2.label"
				},
				{
					"value": "3/4",
					"label": "t:sections.all.image.aspect_ratio.options__3.label"
				},
				{
					"value": "4/3",
					"label": "t:sections.all.image.aspect_ratio.options__4.label"
				},
				{
					"value": "16/9",
					"label": "t:sections.all.image.aspect_ratio.options__5.label"
				},
				{
					"value": "21/9",
					"label": "t:sections.all.image.aspect_ratio.options__6.label"
				},
				{
					"value": "adapt",
					"label": "t:sections.all.image.aspect_ratio.options__7.label"
				},
				{
					"value": "large",
					"label": "t:sections.all.image.aspect_ratio.options__8.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.overlay.header.content"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"min": 0,
			"max": 1,
			"step": 0.1,
			"default": 0.2,
			"label": "t:sections.all.overlay.overlay_opacity.label"
		},
		{
			"type": "checkbox",
			"id": "overlay_link",
			"default": false,
			"label": "t:sections.all.overlay_link.enable.label",
			"info": "t:sections.all.overlay_link.info"
		},
		{
			"type": "header",
			"content": "t:sections.all.content_options.header.content"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "t:sections.all.subheading.label",
			"default": "t:sections.promo-banner.settings.subheading.default"
		},
		{
			"type": "inline_richtext",
			"id": "heading_2",
			"label": "t:sections.all.heading.label",
			"default": "t:sections.promo-banner.settings.heading.default"
		},
		{
			"type": "inline_richtext",
			"id": "description",
			"label": "t:sections.all.text.label",
			"default": "t:sections.promo-banner.settings.description.default"
		},
		{
			"type": "header",
			"content": "t:sections.promo-banner.settings.heading_animation.label"
		},
		{
			"type": "checkbox",
			"id": "is_animated_heading",
			"default": true,
			"label": "t:sections.image-banner.settings.enable_heading_animation.label"
		},
		{
			"type": "range",
			"id": "heading_animation_speed",
			"min": 50,
			"max": 300,
			"step": 50,
			"label": "t:sections.promo-banner.settings.heading_animation_speed.label",
			"default": 150
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "t:sections.all.button.button_label.label",
			"info": "t:sections.promo-banner.settings.button_label.info"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:sections.all.button.button_link.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				}
			],
			"default": "secondary",
			"label": "t:sections.all.button.button_style.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.promo-banner.presets.name"
		}
	]
}
{% endschema %}
