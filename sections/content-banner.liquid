{{ 'section-content-banner.css' | asset_url | stylesheet_tag }}

<script src="{{ 'content-banner.js' | asset_url }}" defer="defer"></script>

{%- style -%}
	{% render 'section-margin' %}
{%- endstyle -%}

{% liquid
	assign color_scheme = section.settings.color_scheme
	assign layout = section.settings.layout
	assign content_alignment = section.settings.content_alignment
	assign button_style = section.settings.button_style
%}

<div class="content-banner animated-text-parent {{ layout }}">
	<div class="content-banner__wrapper color-{{ color_scheme }} {% if section.settings.animated_text %}content-banner__animated scroll-animated-section text-pin-section text-pin-section--{{ layout }}{% endif %}">
		<div class="
				content-banner__grid content-banner__grid--large content-banner__grid--{{ layout }}
				{% if layout == "image_left" or layout == "image_right" %}
				  {% if section.settings.enable_background %} content-banner__grid--background{% endif %}
				  {% if section.settings.notebook_bg %} notebook-bg{% endif %}
				{%endif %}
			">
			<div class="content-banner__media large">
				{%- assign has_image = false -%}
				{%- if section.settings.image != blank -%}
					{%- assign has_image = true -%}
				{%- endif -%}
				{%- assign has_video = false -%}
				{%- if section.settings.video != blank -%}
					{%- assign has_video = true -%}
				{%- endif -%}
							{% liquid
				assign image_loading = 'lazy'
				assign fetch_priority = 'auto'
				if section.index == 1
					assign image_loading = 'eager'
					assign fetch_priority = 'high'
				endif
			%}

				{%- if has_image or has_video -%}
					{%- if layout == 'image_top' or layout == 'image_bottom' -%}
						{%- assign widths = '360, 535, 720, 940, 1070, 1200, 1500, 1780, 2000, 2400, 2800, 3200' -%}
						{%- capture sizes -%}
              (min-width: 1100px) calc(100vw - 126px), calc(100vw - 40px)
            {%- endcapture -%}
					{%- else -%}
						{%- assign widths = '360, 535, 720, 940, 1070, 1200, 1400, 1600' -%}
						{%- capture sizes -%}
              (min-width: 1100px) calc(50vw - 64px), calc(100vw - 40px)
            {%- endcapture -%}
					{%- endif -%}

					{%- if has_image and has_video == false -%}
						{{
							section.settings.image
							| image_url: width: section.settings.image.width
							| image_tag: 									loading: image_loading,
									fetchpriority: fetch_priority, sizes: sizes, widths: widths
						}}
					{%- elsif has_video -%}
						{{
							section.settings.video
							| video_tag:
								loading: 'lazy',
								class: 'data-alt',
								sizes: sizes,
								widths: widths,
								autoplay: true,
								loop: true,
								controls: false,
								muted: true
						}}
					{%- endif -%}
				{%- else -%}
					{{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
				{%- endif -%}

				{%- if layout == 'overlay' -%}
					<div
						class="content-banner__overlay"
						style="opacity: {{ section.settings.overlay_opacity }}"
					></div>
				{%- endif -%}
			</div>

			<div class="content-banner__content content-banner__content--{{ content_alignment }} content-banner__content--{{ layout }}{% if layout == "overlay" %} container{% endif %}">
				{%- if section.settings.heading != blank -%}
					<h2 class="content-banner__heading {{ section.settings.heading_size }}{% if section.settings.animated_text %} animated-text{% endif %}">
						{{ section.settings.heading }}
					</h2>
				{%- endif -%}
				{% if section.settings.button_label != blank %}
					{% render 'button',
						btn_label: section.settings.button_label,
						btn_link: section.settings.button_link,
						btn_style: button_style,
						btn_position: section.settings.button_position,
						add_classes: 'content-banner__button focus-inset'
					%}
				{%- endif -%}
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "t:sections.content-banner.name",
	"class": "content-banner-section spaced-section",
	"tag": "section",
	"enabled_on": {
		"templates": ["*"]
	},
	"settings": [
		{
			"type": "color_scheme",
			"id": "color_scheme",
			"default": "background-1",
			"label": "t:sections.all.color_scheme.label"
		},
		{
			"type": "checkbox",
			"id": "animated_text",
			"default": true,
			"label": "t:sections.content-banner.settings.animated_text.label"
		},
		{
			"type": "checkbox",
			"id": "enable_background",
			"default": false,
			"label": "t:sections.all.enable_background.label",
			"info": "t:sections.content-banner.settings.info_not_overlay"
		},
		{
			"type": "checkbox",
			"id": "notebook_bg",
			"default": false,
			"label": "t:sections.all.notebook_bg.label",
			"info": "t:sections.content-banner.settings.info_not_overlay"
		},
		{
			"type": "select",
			"id": "layout",
			"options": [
				{
					"value": "image_right",
					"label": "t:sections.content-banner.settings.layout.options__2.label"
				},
				{
					"value": "image_left",
					"label": "t:sections.content-banner.settings.layout.options__3.label"
				},
				{
					"value": "overlay",
					"label": "t:sections.content-banner.settings.layout.options__4.label"
				}
			],
			"default": "image_right",
			"label": "t:sections.content-banner.settings.layout.label"
		},
		{
			"type": "select",
			"id": "content_alignment",
			"default": "left",
			"label": "t:sections.all.content_alignment.label",
			"options": [
				{
					"value": "left",
					"label": "t:sections.all.content_alignment.options.options__2.label"
				},
				{
					"value": "center",
					"label": "t:sections.all.content_alignment.options.options__1.label"
				}
			]
		},
		{
			"type": "select",
			"id": "button_position",
			"default": "center",
			"label": "t:sections.all.button.button_position.label",
			"options": [
				{
					"value": "bottom",
					"label": "t:sections.all.button.button_position.options__1.label"
				},
				{
					"value": "center",
					"label": "t:sections.all.button.button_position.options__2.label"
				}
			]
		},
		{
			"type": "header",
			"content": "t:sections.all.image.header.content__1"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "t:sections.all.image.label"
		},
		{
			"type": "video",
			"id": "video",
			"label": "t:sections.all.video.label",
			"info": "t:sections.all.video.info"
		},
		{
			"type": "range",
			"id": "overlay_opacity",
			"step": 0.1,
			"default": 0.2,
			"min": 0,
			"max": 1,
			"info": "t:sections.image-banner.settings.overlay.info",
			"label": "t:sections.all.overlay.overlay_opacity.label_secondary"
		},
		{
			"type": "header",
			"content": "t:sections.all.content_options.header.content"
		},
		{
			"type": "textarea",
			"id": "heading",
			"default": "t:sections.content-banner.settings.heading.default",
			"label": "t:sections.all.text.label__2"
		},
		{
			"type": "select",
			"id": "heading_size",
			"options": [
				{
					"value": "h1",
					"label": "t:sections.all.heading_size.options__1.label"
				},
				{
					"value": "h2",
					"label": "t:sections.all.heading_size.options__2.label"
				},
				{
					"value": "h3",
					"label": "t:sections.all.heading_size.options__3.label"
				}
			],
			"default": "h1",
			"label": "t:sections.all.heading_size.label__2"
		},
		{
			"type": "header",
			"content": "t:sections.all.button.header_button.content"
		},
		{
			"type": "text",
			"id": "button_label",
			"default": "t:sections.all.button.button_label.default_5",
			"label": "t:sections.all.button.button_label.label"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "t:sections.all.button.button_link.label"
		},
		{
			"type": "select",
			"id": "button_style",
			"options": [
				{
					"value": "primary",
					"label": "t:sections.all.button.button_style.options__1.label"
				},
				{
					"value": "secondary",
					"label": "t:sections.all.button.button_style.options__2.label"
				},
				{
					"value": "tertiary",
					"label": "t:sections.all.button.button_style.options__3.label"
				},
				{
					"value": "simple",
					"label": "t:sections.all.button.button_style.options__4.label"
				}
			],
			"default": "simple",
			"label": "t:sections.all.button.button_style.label"
		},
		{
			"type": "header",
			"content": "t:sections.all.section-margin.header.content"
		},
		{
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
	],
	"presets": [
		{
			"name": "t:sections.content-banner.presets.name"
		}
	]
}
{% endschema %}
