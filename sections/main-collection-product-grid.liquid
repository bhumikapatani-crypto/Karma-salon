{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
{%- if settings.pagination_type == 'load_more' or settings.pagination_type == 'infinite_scroll' -%}
  <script src="{{ 'load-more.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script src="{{ 'product-card-swatches.js' | asset_url }}" defer="defer"></script>

{% comment %}theme-check-disable AssetPreload{% endcomment %}
<link rel="preload" href="{{ 'component-card.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="{{ 'component-price.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="{{ 'component-badge.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="{{ 'component-rte.css' | asset_url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
{% comment %}theme-check-enable AssetPreload{% endcomment %}

<noscript>{{ 'component-card.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-price.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-badge.css' | asset_url | stylesheet_tag }}</noscript>
<noscript>{{ 'component-rte.css' | asset_url | stylesheet_tag }}</noscript>

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<script src='{{ 'products-per-row.js' | asset_url }}' defer='defer'></script>

{%- if settings.quickview_show or settings.show_on_mobile -%}
  {% comment %}theme-check-disable AssetPreload{% endcomment %}
  <link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">
  <link
    rel="preload"
    href="{{ 'quick-add.css' | asset_url }}"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  >
  {% comment %}theme-check-enable AssetPreload{% endcomment %}
{%- endif -%}

{%- style -%}
  {% render 'section-margin' %}
{%- endstyle -%}

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

{%- paginate collection.products by section.settings.products_per_page -%}
  {% assign current_page = paginate.current_page %}
  {% assign pages_amount = paginate.pages %}
{%- endpaginate -%}


  <div class="collection-wrapper collection-wrapper--catalog {% if collection.all_products_count == 0 %} collection-wrapper--empty{% endif %}{% if section.settings.enable_filtering == false and section.settings.enable_sorting == false %} collection-wrapper_no-facets{% endif %}"
  >
    {%- if collection.all_products_count > 0 and collection.products_count > 0 -%}
      {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
        {% render 'facets',
          results: collection,
          enable_filtering: section.settings.enable_filtering,
          enable_sorting: section.settings.enable_sorting,
          filter_type: section.settings.filter_type,
          price_info: section.settings.price_info,
          enable_per_row_button: section.settings.enable_per_row_button,
          image_filter_ratio: section.settings.image_filter_ratio,
          image_filter_fit: section.settings.image_filter_fit,
          image_filter_columns: section.settings.image_filter_columns,
          pages_amount: pages_amount,
          current_page: current_page
        %}
      {%- endif -%}
    {%- endif -%}

  <div class="container">
    <div
      id="ProductGridContainer" 
      data-products-in-row='{{ section.settings.default_per_row }}' 
      class="products-grid{% if section.settings.enable_filtering == false and section.settings.enable_sorting == false %} products-grid_no-filter{% endif %}"
    >
      {%- paginate collection.products by section.settings.products_per_page -%}
        {%- if collection.products.size == 0 -%}
          <div
            class="collection collection-product collection--empty container"
            id="product-grid"
            data-id="{{ section.id }}"
          >
            <div class="loading-overlay">
              <div class="loading-overlay__spinner">
                {% render 'icon-spinner' %}
              </div>
            </div>

            <div class="title-wrapper center title-wrapper-empty">
              <div class="title title--primary">
                {% if collection.all_products_count == 0 %}
                  {{ 'sections.collection_template.empty' | t -}}
                  <br>
                {% else %}
                  {{ 'sections.collection_template.empty_results' | t -}}
                  <br>
                  {{
                    'sections.collection_template.results_use_fewer_filters_html'
                    | t: link: collection.url, class: 'underlined-link link'
                  }}
                {% endif %}
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="collection collection-product">
            <div class="loading-overlay">
              <div class="loading-overlay__spinner">
                {% render 'icon-spinner' %}
              </div>
            </div>

            <ul id="product-grid" data-id="{{ section.id }}" class="collection-product-list 
              collection-product-list--{{ section.settings.columns_mobile }}-mobile load-more-grid"
              data-page="{{ paginate.current_page }}"
              data-items-per-page="{{ section.settings.products_per_page }}"
              style="--page: {{ paginate.current_page }}; --per-page: {{ section.settings.products_per_page }}">

              {%- for product in collection.products -%}
                {% liquid 
                  assign first_index = 4
                  assign second_index = 9

                  assign per_row = section.settings.default_per_row
                  if per_row == 'small'
                    assign first_index = 6
                    assign second_index = 13
                  elsif per_row == 'large'
                    assign first_index = 4
                    assign second_index = 7
                  endif

                  if section.blocks[0].settings.description != blank
                    assign first_index = first_index | minus: 1
                  endif

                  if section.blocks[1].settings.description != blank
                    assign second_index = second_index | minus: 1
                  endif
                %}        
                  {% if first_index == forloop.index %}
                    {%- assign ratio_parts = section.settings.image_ratio | split: "/" -%}
                    {%- assign ratio_w = ratio_parts[0] | plus: 0 -%}
                    {%- assign ratio_h = ratio_parts[1] | plus: 0 -%}
                    {%- if section.blocks[0].settings.heading != blank -%}
                      {%- assign ratio_h = ratio_h | divided_by: 2 -%}
                    {%- endif -%}
                    {% if section.blocks[0] %}
                      <li style="--first-forloop-index: {{forloop.index}}" class='collection-product-card first collection-product-card--special color-{{ section.blocks[0].settings.color_scheme }}{% if section.blocks[0].settings.description != blank %} big{% endif %}'>
                        <div class="card-wrapper">
                          <div class="card card--product">
                            <div class="card__inner full-unstyled-link">
                              <div class="media media--transparent media--hover-effect"
                                  style="aspect-ratio: {{ ratio_w }} / {{ ratio_h }};">
                                {% if section.blocks[0].settings.image != blank %}
                                  {{ section.blocks[0].settings.image | image_url: width: section.blocks[0].settings.image.width | image_tag: loading: 'lazy', width: section.blocks[0].settings.image.width, sizes: '100vw', widths: '550, 750, 1100, 1500, 1920' }}
                                {% else %}
                                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                              </div>
                            </div>
                          </div>
                          {% if section.blocks[0].settings.heading != blank or section.blocks[0].settings.description != blank %}
                            <div class='collection-product-card--special__overlay' style='opacity: {{ section.blocks[0].settings.overlay_opacity }}'></div>
                            <div class='collection-product-card--special__text'>
                              {%- if section.blocks[0].settings.heading != blank -%}
                                <h2 class='section-heading__heading {{ section.blocks[0].settings.heading_size }}'>{{ section.blocks[0].settings.heading }}</h2>
                              {%- endif -%}
                              {%- if section.blocks[0].settings.description != blank -%}
                                <p class='section-heading__description'>{{ section.blocks[0].settings.description }}</p>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>
                        {% if section.blocks[0].settings.overlay_link != blank %}
                          <a class="collection-product-card--special__overlay-link" aria-label="collection link" href="{{ section.blocks[0].settings.overlay_link }}"></a>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endif %}

                  {% if second_index == forloop.index %}
                    {%- assign ratio_parts = section.settings.image_ratio | split: "/" -%}
                    {%- assign ratio_w = ratio_parts[0] | plus: 0 -%}
                    {%- assign ratio_h = ratio_parts[1] | plus: 0 -%}
                    {%- if section.blocks[1].settings.heading != blank -%}
                      {%- assign ratio_h = ratio_h | divided_by: 2 -%}
                    {%- endif -%}
                    {%- if section.blocks[1] -%}
                      <li style="--second-forloop-index: {{forloop.index}}" class='collection-product-card second collection-product-card--special color-{{ section.blocks[1].settings.color_scheme }}{% if section.blocks[1].settings.description != blank %} big{% endif %}'>
                        <div class="card-wrapper">
                          <div class="card card--product">
                            <div class="card__inner full-unstyled-link">
                              <div class="media media--transparent media--hover-effect"
                                  style="aspect-ratio: {{ ratio_w }} / {{ ratio_h }};">
                                {% if section.blocks[1].settings.image != blank %}
                                  {{ section.blocks[1].settings.image | image_url: width: section.blocks[1].settings.image.width | image_tag: loading: 'lazy', width: section.blocks[1].settings.image.width, sizes: '100vw', widths: '550, 750, 1100, 1500, 1920' }}
                                {% else %}
                                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                              </div>
                            </div>
                          </div>
                          {% if section.blocks[1].settings.heading != blank or section.blocks[1].settings.description != blank %}
                            <div class='collection-product-card--special__overlay' style='opacity: {{ section.blocks[1].settings.overlay_opacity }}'></div>
                            <div class='collection-product-card--special__text'>
                              {%- if section.blocks[1].settings.heading != blank -%}
                                <h2 class='section-heading__heading {{ section.blocks[1].settings.heading_size }}'>{{ section.blocks[1].settings.heading }}</h2>
                              {%- endif -%}
                              {%- if section.blocks[1].settings.description != blank -%}
                                <p class='section-heading__description'>{{ section.blocks[1].settings.description }}</p>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>
                        {% if section.blocks[1].settings.overlay_link != blank %}
                          <a class="collection-product-card--special__overlay-link" aria-label="collection second link" href="{{ section.blocks[1].settings.overlay_link }}"></a>
                        {% endif %}
                      </li>
                    {%- endif -%}
                  {% endif %}

                <li class="collection-product-card {% if settings.quickview_hover %}quickview--hover{% endif %}">
                  {% render 'product-card',
                    product_card_product: product,
                    media_size: section.settings.image_ratio,
                    media_fit: section.settings.image_fit,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_collection: section.settings.show_collection,
                    show_desc: section.settings.show_desc,
                    columns: 4,
                    section_id: section.id,
                    add_id: forloop.index
                  %}
                </li>
              {%- endfor -%}

            </ul>

            {%- if paginate.pages > 1 -%}
              {%- if settings.pagination_type == 'load_more' -%}
                {% render 'load-more',
                  next_url: paginate.next.url,
                  count_pages: paginate.pages,
                  current_page: paginate.current_page
                %}
                <div class="js-hidden">
                  {% render 'pagination', paginate: paginate %}
                </div>
              {%- elsif settings.pagination_type == 'infinite_scroll' -%}
                {% render 'infinite-scroll',
                  next_url: paginate.next.url,
                  count_pages: paginate.pages,
                  current_page: paginate.current_page
                %}
                <div class="js-hidden">
                  {% render 'pagination', paginate: paginate %}
                </div>
              {% else %}
                {% render 'pagination', paginate: paginate %}
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-collection-product-grid.name",
  "tag": "section",
  "class": "collection-grid-section",
  "blocks": [
		{
			"type": "image",
			"name": "t:sections.main-collection-product-grid.settings.promo_block.name",
			"limit": 2,
			"settings": [
				{
					"type": "paragraph",
					"content": "t:sections.main-collection-product-grid.settings.promo_block.content"
				},
				{
					"type": "image_picker",
					"id": "image",
					"label": "t:sections.all.image.label"
				},
				{
					"type": "text",
					"id": "heading",
					"label": "t:sections.all.heading.label"
				},
				{
					"type": "select",
					"id": "heading_size",
					"options": [
						{
							"value": "h2",
							"label": "t:sections.all.heading_size.options__1.label"
						},
						{
							"value": "h3",
							"label": "t:sections.all.heading_size.options__2.label"
						},
						{
							"value": "h4",
							"label": "t:sections.all.heading_size.options__3.label"
						}
					],
					"default": "h4",
					"label": "t:sections.all.heading_size.label"
				},
				{
					"type": "inline_richtext",
					"id": "description",
					"label": "t:sections.all.text.label",
					"info": "t:sections.main-collection-product-grid.settings.promo_block.info"
				},
        {
          "type": "url",
          "id": "overlay_link",
          "label": "t:sections.all.overlay_link.label"
        },
				{
					"type": "color_scheme",
					"id": "color_scheme",
					"default": "background-2",
					"label": "t:sections.all.color_scheme.label"
				},
				{
					"type": "range",
					"id": "overlay_opacity",
					"min": 0,
					"max": 1,
					"step": 0.1,
					"default": 0.1,
					"label": "t:sections.all.overlay.overlay_opacity.label_secondary"
				}
			]
		}
	],
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "min": 2,
      "max": 44,
      "step": 1,
      "default": 12,
      "label": "t:sections.main-collection-product-grid.settings.products_per_page.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.mobile_options.header.content"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "1",
      "label": "t:sections.all.mobile_options.columns.label",
      "options": [
        {
          "value": "1",
          "label": "t:sections.all.mobile_options.columns.options__1.label"
        },
        {
          "value": "2",
          "label": "t:sections.all.mobile_options.columns.options__2.label"
        }
      ]
    },
    {
			"type": "header",
			"content": "t:sections.main-collection-product-grid.settings.per_row.header.content"
		},
		{
			"type": "checkbox",
			"id": "enable_per_row_button",
			"default": true,
			"label": "t:sections.main-collection-product-grid.settings.per_row.enable_per_row_button.label"
		},
		{
			"type": "select",
			"id": "default_per_row",
			"label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.label",
      "info": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.info",
			"default": "small",
			"options": [
				{
					"value": "small",
					"label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.options__1.label"
				},
				{
					"value": "medium",
					"label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.options__2.label"
				},
        {
					"value": "large",
					"label": "t:sections.main-collection-product-grid.settings.per_row.default_per_row.options__3.label"
				}
			]
		},
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_filtering.label",
      "info": "t:sections.main-collection-product-grid.settings.enable_filtering.info"
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "default": true,
      "label": "t:sections.main-collection-product-grid.settings.enable_sorting.label"
    },
    {
      "type": "checkbox",
      "id": "price_info",
      "label": "t:sections.filters.price_info.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-product-grid.settings.image_filter.content"
    },
    {
      "type": "select",
      "id": "image_filter_ratio",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.card.image_ratio.options__3.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.card.image_ratio.options__1.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.card.image_ratio.options__2.label"
        }
      ],
      "default": "3/4",
      "label": "t:sections.all.card.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_filter_fit",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.card.image_fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.card.image_fit.options__2.label"
        }
      ],
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label"
    },
    {
      "type": "range",
      "id": "image_filter_columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 2,
      "label": "t:sections.main-collection-product-grid.settings.image_filter_columns.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.card.header_card.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "default": "3/4",
      "label": "t:sections.all.card.image_ratio.label",
      "options": [
        {
          "value": "1/1",
          "label": "t:sections.all.image.aspect_ratio.options__1.label"
        },
        {
          "value": "3/2",
          "label": "t:sections.all.image.aspect_ratio.options__2.label"
        },
        {
          "value": "3/4",
          "label": "t:sections.all.image.aspect_ratio.options__3.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "default": "cover",
      "label": "t:sections.all.card.image_fit.label",
      "options": [
        {
          "value": "contain",
          "label": "t:sections.all.image.fit.options__1.label"
        },
        {
          "value": "cover",
          "label": "t:sections.all.image.fit.options__2.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": true,
      "label": "t:sections.all.card.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "t:sections.all.card.show_vendor.label"
    },
    {
      "type": "checkbox",
      "id": "show_collection",
      "default": false,
      "label": "t:sections.all.card.show_collection.label"
    },
    {
      "type": "checkbox",
      "id": "show_desc",
      "default": false,
      "label": "t:sections.all.card.show_desc.label",
      "info": "t:sections.all.card.show_desc.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.section-margin.header.content"
    },
    {
			"type": "select",
			"id": "margin_top",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "no-indent",
			"label": "t:sections.all.section-margin.margin_top.label"
		},
		{
			"type": "select",
			"id": "margin_bottom",
			"options": [
				{
					"value": "no-indent",
					"label": "t:sections.all.section-margin.options__1.label"
				},
				{
					"value": "s",
					"label": "t:sections.all.section-margin.options__3.label"
				},
				{
					"value": "m",
					"label": "t:sections.all.section-margin.options__4.label"
				},
				{
					"value": "l",
					"label": "t:sections.all.section-margin.options__5.label"
				}
			],
			"default": "m",
			"label": "t:sections.all.section-margin.margin_bottom.label"
		}
  ]
}
{% endschema %}