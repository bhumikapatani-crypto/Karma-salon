{% comment %}
  	Renders an article card for a given blog with settings to either show the image or not.

  	Accepts:
  	- blog: {Object} Blog object
  	- article: {Object} Article object
  	- show_image: {Boolean} The setting either show the article image or not. If it's not included it will show the image by default
  	- show_date: {String} The setting either show the article date or not. If it's not included it will not show the image by default
  	- show_author: {String} The setting either show the article author or not. If it's not included it will not show the author by default
    - layout: {String} The setting defining the layout of the cards.  If it's not included it will show the layout 3 by default

  	Usage:
  {% render 'article-card' blog: blog, article: article, show_image: section.settings.show_image %}
{% endcomment %}

<article class="article-card{% if layout %} article-card--{{ layout }}{% endif %}" aria-labelledby="Article-{{ article.id }}">
  {% if layout_4 %}
    <div class="article-card__overlay-4" style="opacity: {{ section.settings.overlay_opacity }}"></div>
  {% endif %}
  <a
    class="article-card-link"
    tabindex="-1"
    href="{{ article.url }}"
    aria-label="{{ 'accessibility.article_link' | t }}"
  ></a>
  <div class="article-card__image-wrapper{% if show_image %} has-ratio{% endif %}">
    <a
      href="{{ article.url }}"
      class="article-card__image"
      aria-label="{{ 'accessibility.article_link' | t }}"
    >
    {% if show_image == true %}
      {%- if article.image != blank-%}
        {% capture sizes %}
          (min-width: 990px) 940px, (min-width: 750px) calc((100vw - 40px) / 2), calc((100vw - 40px))
        {% endcapture %}
        {{
          article.image
          | image_url: width: 1066
          | image_tag:
            loading: 'lazy',
            sizes: sizes,
            widths: '165, 360, 535, 720, 940, 1066'
        }}
        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
      {%- endif -%}
    {% endif %}
    </a>
    {% if layout == "layout1" %}
      {%- if show_tags and article.tags != blank -%}
        <div class="article-card__tags article-card__block-on-image{% if blog.url == blank %} no-events{% endif %}">
          {% for tag in article.tags %}
              {% if blog.url != blank %}
                <a
                  href="{{ blog.url }}/tagged/{{ tag | handle }}"
                  aria-label="{{ tag }}"
                  class="article-card__tag subheading"
                >
                  <span title="{{ tag }}">
                    {{- tag }}
                  </span>
                </a>
              {% else %}
                <div class="article-card__tag subheading">
                  <span title="{{ tag }}">
                    {{- tag }}
                  </span>
                </div>
              {% endif %}
            {% if forloop.last == false %}
              <span class="article-card__tags-separator">&nbsp;{% if layout == "layout2" %}/{% endif %}&nbsp;</span>
            {% endif %}
          {% endfor %}
        </div>
      {%- endif -%}
    {% elsif layout == "layout2" %}
      {%- if show_date -%}
        <span class="article-card__date layout2 secondary_text article-card__block-on-image{% if blog.url == blank %} no-events{% endif %}">
          {{- article.published_at | date: '%b %d, %Y' -}}
        </span>
      {%- endif -%}
    {% endif %}
  </div>
  <header class="article-card__header">
    {% if layout_4 and first %}
      <a
        class="article-card-link"
        href="{{ article.url }}"
        tabindex="-1"
        aria-label="{{ 'accessibility.article_link' | t }}"
      ></a>
    {% endif %}
    <div class="article-card__content-wrapper">
      {% if layout == "layout1" %}<div class="article-card__title-wrapper-layout1">{% endif %}
        <h4
          class="article-card__title {% if layout_4 and first %}h1{% else %}h3{% endif %}"
          id="Article-{{ article.id }}"
        >
          <a
            href="{{ article.url }}"
            aria-label="{{ article.title | escape }}"
          >
            {{ article.title | escape }}
          </a>
        </h4>
        {% if layout == "layout1" %}
          {%- if show_date or show_tags or show_author -%}
            <div class="article-card__meta article-card__meta--author-tags">
              {%- if show_date or show_author -%}
                <div class="article-card__info">
                  {%- if show_author -%}
                    <div class="article-card__author secondary_text">
                      <span>
                        {{- article.author -}}
                      </span>
                    </div>
                  {%- endif -%}
                  {% if layout != "layout2" %}
                    {%- if show_date -%}
                      <span class="article-card__date secondary_text{% if blog.url == blank %} no-events{% endif %}">
                        {{- article.published_at | date: '%b %d, %Y' -}}
                      </span>
                    {%- endif -%}
                  {% endif %}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {% endif %}
      {% if layout == "layout1" %}</div>{% endif %}
      {%- if show_excerpt and article.excerpt_or_content.size > 0 -%}
        <p class="article-card__excerpt {% if template == 'search' %} article-card__excerpt_small {% endif %}">
          {{ article.excerpt_or_content | strip_html | truncate: 150 }}
        </p>
      {%- endif -%}
    </div>
    {% if layout != "layout1" %}
      {%- if show_date or show_tags or show_author -%}
        <div class="article-card__meta article-card__meta--author-tags">
          {% if layout != "layout1" or layout == blank %}
            {%- if show_tags and article.tags != blank -%}
              <div class="article-card__tags{% if blog.url == blank %} no-events{% endif %} {% if layout_4 and first %}color-background-1{% endif %}">
                {% for tag in article.tags %}
                    {% if blog.url != blank %}
                      <a
                        href="{{ blog.url }}/tagged/{{ tag | handle }}"
                        aria-label="{{ tag }}"
                        class="article-card__tag subheading"
                      >
                        <span title="{{ tag }}">
                          {{- tag }}
                        </span>
                      </a>
                    {% else %}
                      <div class="article-card__tag subheading">
                        <span title="{{ tag }}">
                          {{- tag }}
                        </span>
                      </div>
                    {% endif %}
                  {% if forloop.last == false %}
                    <span class="article-card__tags-separator">&nbsp;{% if layout == "layout2" %}/{% endif %}&nbsp;</span>
                  {% endif %}
                {% endfor %}
              </div>
            {%- endif -%}
          {% endif %}
          {%- if show_date or show_author -%}
            <div class="article-card__info">
              {%- if show_author -%}
                <div class="article-card__author secondary_text">
                  <span>
                    {{- article.author -}}
                  </span>
                </div>
              {%- endif -%}
              {% if layout != "layout2" %}
                {%- if show_date -%}
                  <span class="article-card__date secondary_text{% if blog.url == blank %} no-events{% endif %}">
                    {{- article.published_at | date: '%b %d, %Y' -}}
                  </span>
                {%- endif -%}
              {% endif %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {% endif %}
    {%- if show_count_comments
      and article.comments_count > 0
      and blog.comments_enabled?
    -%}
      <div class="article-card__meta">
        <span class="article-card__comments">
          {{- 'blogs.article.comments' | t: count: article.comments_count -}}
        </span>
      </div>
    {%- endif -%}
  </header>
</article>
