<div class="product-carousel {% if search_menu.links.size > 0 %}shwo_promo_menu{% endif %}">
	{% if heading != blank %}
    <span class="promo-block__heading subheading">
      {{- heading -}}
    </span>
  {% endif %}
	<div class="product-carousel-main product-4">
		<div class="swiper product-carousel-swiper swiper-container">
			<div
				class="swiper-wrapper product-carousel__wrapper list-unstyled products--{{ columns_mobile }}-items-mobile"
				data-count="4"
				data-count-mobile="{{ columns_mobile }}"
				data-margin="{{ margin }}"
			>
				{%- for product in product -%}
					<div class="
							collection-product-card swiper-slide
							quickview{%- if settings.quickview_hover -%}--hover{% endif %}
						">
						{% render 'product-card',
							product_card_product: product,
							media_size: image_ratio,
							media_fit: image_fit,
							show_secondary_image: show_secondary_image,
							section_id: block.id,
							columns: columns_per_row,
							add_id: forloop.index
						%}
					</div>
				{%- else -%}
					{%- for i in (1..8) -%}
						<div class="collection-product-card swiper-slide">
							{% render 'product-card-placeholder', media_size: image_ratio, forloop: forloop, show_vendor: section.settings.show_vendor, %}
						</div>
					{%- endfor -%}
				{%- endfor -%}
			</div>
		</div>
		{% if show_arrows %}
			<div class="carousel__button-prev swiper-button swiper-button-prev">
				<div class="svg-embed">{% render 'icon-arrow' %}</div>
			</div>
			<div class="carousel__button-next swiper-button swiper-button-next">
				<div class="svg-embed">{% render 'icon-arrow' %}</div>
			</div>

			<script>
				(function () {
					function adjustButtonPosition(height) {
						document.querySelectorAll(`#shopify-section-{{ section.id }} .swiper-button`).forEach((button) => {
							button.style.top = height / 2 + 'px';
						});
					}

					function changePosition() {
						if (window.innerWidth < 1100) return;

						const image = document.querySelector(`#shopify-section-{{ section.id }} .img_tag`);

						if (image) {
							if (image.tagName === 'IMG') {
								if (image.complete) {
									adjustButtonPosition(image.offsetHeight);
								} else {
									image.addEventListener('load', function () {
										adjustButtonPosition(this.offsetHeight);
									});
								}
							} else if (image.tagName === 'svg') {
								const height = image.getBoundingClientRect().height;
								adjustButtonPosition(height);
							}
						}
					}

					changePosition();

					document.addEventListener('shopify:section:load', changePosition);

					let resizeTimeout;
					window.addEventListener('resize', function () {
						clearTimeout(resizeTimeout);
						resizeTimeout = setTimeout(changePosition, 100);
					});
				})();
			</script>
		{% endif %}
		{% if show_bullets %}
			<div class="product-carousel__pagination swiper-pagination"></div>
		{% endif %}
	</div>
</div>
