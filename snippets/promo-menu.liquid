<div class="promo-menu">
  {% if heading != blank %}
    <span class="promo-menu__heading subheading">
      {{- heading -}}
    </span>
  {% endif %}
  <ul class="promo-menu__list list-unstyled" role="list">
    {%- for link in search_menu.links -%}
      <li class="promo-menu__item">
        <a
          href="{{ link.url }}"
          {% if settings.open_new_tab and link.type == 'http_link' %}
            target="_blank"
          {% endif %}
          class="promo-menu__link"
          aria-label="{{- link.title -}}"
        >
          <span>{{ link.title }}</span>
        </a>
      </li>
    {%- endfor -%}
  </ul>
</div>
