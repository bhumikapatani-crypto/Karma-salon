{% liquid
    assign is_mobile = is_mobile | default: false
  %}
  
  {%- if shop.customer_accounts_enabled and section.settings.enable_account_btn -%}
      <div class="header__account {% if is_mobile %}header__account--mobile{% endif %}">
        {% if section.settings.enable_account_modal_component %}
          <shopify-account
            menu="{{ section.settings.customer_account_menu | default: "customer-account-main-menu" }}"
            style="display: flex; align-items: center;"
          >
            <div slot="signed-out-avatar">
                <div class="header__icon header__icon--account line-link header__icon--summary modal__toggle">
                    {% render 'icon-account' %}
                </div>              
            </div>
          </shopify-account>
        {%- else -%}
          {% liquid
            if customer
              assign btn_link = routes.account_profile_url
              assign btn_aria = 'customer.account_fallback' | t
            else
              assign btn_link = routes.account_login_url
              assign btn_aria = 'customer.log_in' | t
            endif
          %}

          {% if is_mobile != true %}
            <details-disclosure class="header__account">
              <details>
                <summary
                  class="header__icon header__icon--account link--text header__icon--summary focus-inset modal__toggle"
                  aria-haspopup="dialog"
                  role="button"
                >
                  {% render 'icon-account' %}
                </summary>
                <div
                  class="header__account-modal modal__toggle color-background-1"
                  role="dialog"
                  aria-modal="true"
                >
                  {%- if customer -%}
                    <div class="header__account__account">
                      <div class="header__account__name subheading">{{ customer.name }}</div>
                      <ul class="header__account__body">
                        <li class="header__account__link">
                          <a
                            href="{{ routes.account_profile_url }}"
                            aria-label="{{ 'customer.account_fallback' | t }}"
                          >
                            {{ 'customer.account_fallback' | t }}
                          </a>
                        </li>
                      </ul>
                      <a
                        class="header__account__logout button button--primary button--primary-size focus-inset"
                        href="{{ routes.account_logout_url }}"
                        data-button-text="{{ 'customer.log_out' | t }}"
                        aria-label="{{ 'customer.log_out' | t }}"
                      >
                        <span>
                          {{ 'customer.log_out' | t }}
                        </span>
                      </a>
                    </div>
                  {%- else -%}
                    <a
                      href="{{ btn_link }}"
                      aria-label="{{ btn_aria }}"
                      class="button button--tertiary button--primary-size button header__account__login link focus-inset"
                      {%- if customer -%}
                        data-button-text="{{ 'customer.account_fallback' | t }}"
                      {%- else -%}
                        data-button-text="{{ 'customer.log_in' | t }}"
                      {%- endif -%}
                    >
                      <span>
                        {% if customer %}
                          {{ 'customer.account_fallback' | t }}
                        {% else %}
                          {{ 'customer.log_in' | t }}
                        {% endif %}
                      </span>
                    </a>
                  {%- endif -%}
                </div>
              </details>
            </details-disclosure>
          {% else %}
            {%- if customer -%}
              <div class="menu-drawer__utility-account">
                <div class="menu-drawer__utility-account-header">
                  <span class="menu-drawer__utility-name">
                    {{- customer.name -}}
                  </span>
                  <a
                    class="menu-drawer__utility-logout"
                    href="{{ routes.account_logout_url }}"
                    aria-label="{{ 'customer.log_out' | t }}"
                  >
                    {{- 'customer.log_out' | t -}}
                  </a>
                </div>
                <ul class="menu-drawer__utility-account-body">
                  <li class="menu-drawer__utility-account-cart">
                    <a
                      href="{{ routes.cart_url }}"
                      aria-label="{{ 'customer.account.shopping_cart' | t }}"
                    >
                      {{- 'customer.account.shopping_cart' | t -}}
                    </a>
                    {%- if cart != empty -%}
                      <div class="cart-count-bubble">
                        {%- if cart.item_count < 100 -%}
                          <span aria-hidden="true">
                            {{- cart.item_count -}}
                          </span>
                        {%- endif -%}
                        <span class="visually-hidden">
                          {{-
                            'sections.header.cart_count'
                            | t: count: cart.item_count
                          -}}
                        </span>
                      </div>
                    {%- endif -%}
                  </li>
                  <li class="menu-drawer__utility-account-link">
                    <a
                      href="{{ routes.account_profile_url }}"
                      aria-label="{{ 'customer.account.title' | t }}"
                    >
                      {{ 'customer.account.title' | t }}
                    </a>
                  </li>
                </ul>
              </div>
            {%- else -%}
              <a
                href="{{ btn_link }}"
                aria-label="{{ btn_aria }}"
                class="button button--primary button--primary-size menu-drawer__account link focus-inset"
              >
                {%- liquid
                  if customer
                    echo 'customer.account_fallback' | t
                  else
                    echo 'customer.log_in' | t
                  endif
                -%}
              </a>
            {%- endif -%}
          {% endif %}
          
        {%- endif -%}
      </div>
    {%- endif -%}